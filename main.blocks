-----------------------------------
</comment><block type="pxt-on-start" id="p/Cy]5,#7njt8D[S3~Bb" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="JH*,Vw3{;OYX+K)v`n({"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace PlanetX_AILens {" line1="    const CameraAdd = 0X14;" line2="    let DataBuff = pins.createBuffer(9);" line3="    /**" line4="    * Status List of Ball" line5="    */" line6="    export enum FuncList {" line7="        //% block=&quot;Card recognition&quot;" line8="        Card = 2," line9="        //% block=&quot;Face recognition&quot; " line10="        Face = 6," line11="        //% block=&quot;Ball recognition&quot;" line12="        Ball = 7," line13="        //% block=&quot;Tracking recognition&quot;" line14="        Tracking = 8," line15="        //% block=&quot;Color recognition&quot;" line16="        Color = 9," line17="        //% block=&quot;Learn Object&quot;" line18="        Things = 10" line19="    }" line20="    /**" line21="    * Status List of Ball" line22="    */" line23="    export enum Ballstatus {" line24="        //% block=&quot;X&quot;" line25="        X = 2," line26="        //% block=&quot;Y&quot;" line27="        Y = 3," line28="        //% block=&quot;Size&quot;" line29="        Size = 4," line30="        //% block=&quot;Confidence level &quot;" line31="        Confidence = 6," line32="        //% block=&quot;Ball ID&quot;" line33="        ID = 8" line34="    }" line35="    /**" line36="    * Status List of Face" line37="    */" line38="    export enum Facestatus {" line39="        //% block=&quot;X&quot;" line40="        X = 2," line41="        //% block=&quot;Y&quot;" line42="        Y = 3," line43="        //% block=&quot;W&quot;" line44="        W = 4," line45="        //% block=&quot;H&quot;" line46="        H = 5," line47="        //% block=&quot;Confidence level &quot;" line48="        Confidence = 6," line49="        //% block=&quot;Face ID&quot;" line50="        ID = 8" line51="    }" line52="    /**" line53="    * Status List of Card" line54="    */" line55="    export enum Cardstatus {" line56="        //% block=&quot;X&quot;" line57="        X = 2," line58="        //% block=&quot;Y&quot;" line59="        Y = 3," line60="        //% block=&quot;Size&quot;" line61="        Size = 4," line62="        //% block=&quot;Confidence level &quot;" line63="        Confidence = 6," line64="        //% block=&quot;Card ID&quot;" line65="        ID = 8" line66="    }" line67="    /**" line68="    * Status List of Color" line69="    */" line70="    export enum Colorstatus {" line71="        //% block=&quot;X&quot;" line72="        X = 2," line73="        //% block=&quot;Y&quot;" line74="        Y = 3," line75="        //% block=&quot;Size&quot;" line76="        Size = 4," line77="        //% block=&quot;Confidence level &quot;" line78="        Confidence = 6," line79="        //% block=&quot;Color ID&quot;" line80="        ID = 8" line81="    }" line82="    /**" line83="    * Status List of Color" line84="    */" line85="    export enum ColorLs {" line86="        //% block=&quot;Black&quot;" line87="        black = 4," line88="        //% block=&quot;Blue&quot;" line89="        blue = 2," line90="        //% block=&quot;Green&quot;" line91="        green = 1," line92="        //% block=&quot;Red&quot;" line93="        red = 5," line94="        //% block=&quot;White&quot;" line95="        white = 6," line96="        //% block=&quot;Yellow&quot;" line97="        yellow = 3" line98="    }" line99="" line100="    export enum Linestatus {" line101="        //% block=&quot;Angle&quot;" line102="        angle = 1," line103="        //% block=&quot;Width&quot;" line104="        width = 2," line105="        //% block=&quot;Len&quot;" line106="        len = 3" line107="    }" line108="    export enum LineTrend {" line109="        //% block=&quot;Left&quot;" line110="        left," line111="        //% block=&quot;Right&quot;" line112="        right," line113="        //% block=&quot;Front&quot;" line114="        front," line115="        //% block=&quot;None&quot;" line116="        none" line117="    }" line118="    /**" line119="    * Number Cards List" line120="    */" line121="    export enum numberCards {" line122="        //% block=&quot;0&quot;" line123="        zero = 1," line124="        //% block=&quot;1&quot;" line125="        one = 2," line126="        //% block=&quot;2&quot;" line127="        two = 3," line128="        //% block=&quot;3&quot;" line129="        three = 4," line130="        //% block=&quot;4&quot;" line131="        four = 5," line132="        //% block=&quot;5&quot;" line133="        five = 6," line134="        //% block=&quot;6&quot;" line135="        six = 7," line136="        //% block=&quot;7&quot;" line137="        seven = 8," line138="        //% block=&quot;8&quot;" line139="        eight = 9," line140="        //% block=&quot;9&quot;" line141="        nine = 10" line142="    }" line143="    /*" line144="    * Letters Cards List" line145="    */" line146="    export enum letterCards {" line147="        //% block=&quot;A&quot;" line148="        A = 1," line149="        //% block=&quot;B&quot;" line150="        B = 2," line151="        //% block=&quot;C&quot;" line152="        C = 3," line153="        //% block=&quot;D&quot;" line154="        D = 4," line155="        //% block=&quot;E&quot;" line156="        E = 5" line157="    }" line158="    /*" line159="    * Traffic Cards List" line160="    */" line161="    export enum trafficCards {" line162="        //% block=&quot;Forward&quot;" line163="        forward = 18," line164="        //% block=&quot;Back&quot;" line165="        back = 20," line166="        //% block=&quot;Stop&quot;" line167="        stop = 19," line168="        //% block=&quot;Turn left&quot;" line169="        turnleft = 16," line170="        //% block=&quot;Turn right&quot;" line171="        turnright = 17" line172="    }" line173="    /*" line174="    * Other Cards List" line175="    */" line176="    export enum otherCards {" line177="        //% block=&quot;Mouse&quot;" line178="        mouse = 1," line179="        //% block=&quot;micro:bit&quot;" line180="        microbit = 2," line181="        //% block=&quot;Ruler&quot;" line182="        ruler = 3," line183="        //% block=&quot;Cat&quot;" line184="        cat = 4," line185="        //% block=&quot;Pear&quot;" line186="        pear = 5," line187="        //% block=&quot;Ship&quot;" line188="        ship = 6," line189="        //% block=&quot;Apple&quot;" line190="        apple = 7," line191="        //% block=&quot;Car&quot;" line192="        car = 8," line193="        //% block=&quot;Pen&quot;" line194="        pen = 9," line195="        //% block=&quot;Dog&quot;" line196="        dog = 10," line197="        //% block=&quot;Umbrella&quot;" line198="        umbrella = 11," line199="        //% block=&quot;Airplane&quot;" line200="        airplane = 12," line201="        //% block=&quot;Clock&quot;" line202="        clock = 13," line203="        //% block=&quot;Grape&quot;" line204="        grape = 14," line205="        //% block=&quot;Cup&quot;" line206="        cup = 15" line207="    }" line208="    export enum learnID {" line209="        ID1 = 1," line210="        ID2 = 2," line211="        ID3 = 3," line212="        ID4 = 4," line213="        ID5 = 5" line214="    }" line215="    export enum ballColorList {" line216="        //% block=&quot;Red&quot;" line217="        Red = 2," line218="        //% block=&quot;Blue&quot;" line219="        Blue = 1" line220="    }" line221="    /////////ASR" line222="    export enum vocabularyList {" line223="        //% block=&quot;Hi, Shaun&quot;" line224="        Hi_Shaun = 1," line225="        //% block=&quot;Lights on&quot;" line226="        Turn_on_lights = 16," line227="        //% block=&quot;Lights off&quot;" line228="        Turn_off_lights = 17," line229="        //% block=&quot;Turn left&quot;" line230="        Turn_left = 18," line231="        //% block=&quot;Turn right&quot;" line232="        Turn_right = 19," line233="        //% block=&quot;Full speed ahead&quot;" line234="        Go_forward = 20," line235="        //% block=&quot;Reversing&quot;" line236="        Go_Backwards = 21," line237="        //% block=&quot;Line Tracking&quot;" line238="        Line_tacking = 22," line239="        //% block=&quot;Avoid object&quot;" line240="        Avoid_object = 23," line241="        //% block=&quot;Stop&quot;" line242="        Stop_car = 24," line243="        //% block=&quot;Start device&quot;" line244="        Start_device = 32," line245="        //% block=&quot;Turn off device&quot;" line246="        Close_device = 33," line247="        //% block=&quot;Pause&quot;" line248="        Pause_device = 34," line249="        //% block=&quot;Keep going&quot;" line250="        Keep_going = 35," line251="        //% block=&quot;Raise a level&quot;" line252="        Add_a_level = 36," line253="        //% block=&quot;Lower a level&quot;" line254="        Lower_a_level = 37," line255="        //% block=&quot;Music on&quot;" line256="        Music_on = 38," line257="        //% block=&quot;Music off&quot;" line258="        Music_off = 39," line259="        //% block=&quot;Switch music&quot;" line260="        Switch_music = 40," line261="        //% block=&quot;Execute function one&quot;" line262="        Execute_function_one = 49," line263="        //% block=&quot;Execute function two&quot;" line264="        Execute_function_two = 50," line265="        //% block=&quot;Learning entry 1&quot;" line266="        Learning_entry_1 = 80," line267="        //% block=&quot;Learning entry 2&quot;" line268="        Learning_entry_2 = 81," line269="        //% block=&quot;Learning entry 3&quot;" line270="        Learning_entry_3 = 82," line271="        //% block=&quot;Learning entry 4&quot;" line272="        Learning_entry_4 = 83," line273="        //% block=&quot;Learning entry 5&quot;" line274="        Learning_entry_5 = 84," line275="        //% block=&quot;Learning entry 6&quot;" line276="        Learning_entry_6 = 85," line277="        //% block=&quot;Learning entry 7&quot;" line278="        Learning_entry_7 = 86," line279="        //% block=&quot;Learning entry 8&quot;" line280="        Learning_entry_8 = 87," line281="        //% block=&quot;Learning entry 9&quot;" line282="        Learning_entry_9 = 88," line283="        //% block=&quot;Learning entry 10&quot;" line284="        Learning_entry_10 = 89" line285="    }" line286="    /**" line287="    * TODO: Waiting for module initialize." line288="    */" line289="    //% block=&quot;Initialize AI-Lens&quot;" line290="    //% group=&quot;Basic&quot; weight=100" line291="    //% color=#00B1ED" line292="    export function initModule(): void {" line293="        let timeout = input.runningTime()" line294="        while (!(pins.i2cReadNumber(CameraAdd, NumberFormat.Int8LE))) {" line295="            if (input.runningTime() - timeout &gt; 30000) {" line296="                while (true) {" line297="                    basic.showString(&quot;Init AILens Error!&quot;)" line298="                }" line299="            }" line300="        }" line301="    }" line302="    /**" line303="    * TODO: Switch recognition objects." line304="    * @param fun Function list eg: FuncList.Face" line305="    */" line306="    //% block=&quot;Switch function as %fun&quot;" line307="    //% fun.fieldEditor=&quot;gridpicker&quot;" line308="    //% fun.fieldOptions.columns=3" line309="    //% group=&quot;Basic&quot; weight=95 " line310="    //% color=#00B1ED" line311="    export function switchfunc(fun: FuncList): void {" line312="        let funcBuff = pins.i2cReadBuffer(CameraAdd, 9)" line313="        funcBuff[0] = 0x20" line314="        funcBuff[1] = fun" line315="        pins.i2cWriteBuffer(CameraAdd, funcBuff)" line316="    }" line317="" line318="    /**" line319="    * TODO: Get the image in a frame" line320="    */" line321="    //% block=&quot;Get one image from AI-Lens&quot;" line322="    //% group=&quot;Basic&quot; weight=90 " line323="    //% color=#00B1ED" line324="    export function cameraImage(): void {" line325="        DataBuff = pins.i2cReadBuffer(CameraAdd, 9)" line326="        basic.pause(30)" line327="    }" line328="" line329="    /**" line330="    * TODO: Judge the image contains a ball" line331="    */" line332="    //% block=&quot;Image contains ball(s)&quot;" line333="    //% group=&quot;Ball&quot; weight=85 " line334="    //% color=#00B1ED" line335="    export function checkBall(): boolean {" line336="        return DataBuff[0] == 7" line337="    }" line338="    //% block=&quot;Image contains %ballcolor ball&quot;" line339="    //% group=&quot;Ball&quot; weight=84" line340="    //% ballcolor.fieldEditor=&quot;gridpicker&quot;" line341="    //% ballcolor.fieldOptions.columns=2 " line342="    //% color=#00B1ED" line343="    export function ballColor(ballcolor: ballColorList): boolean {" line344="        if (DataBuff[0] == 7) {" line345="            return ballcolor == DataBuff[1]" line346="        }" line347="        else {" line348="            return false" line349="        }" line350="    }" line351="    //% block=&quot;In the image get ball(s)' total&quot;" line352="    //% group=&quot;Ball&quot; weight=83 " line353="    //% color=#00B1ED" line354="    export function BallTotalNum(): number {" line355="        if (DataBuff[0] == 7) {" line356="            return DataBuff[7]" line357="        }" line358="        else {" line359="            return 0" line360="        }" line361="    }" line362="    /**" line363="    * TODO: In the image get ball(s)' info" line364="    */" line365="    //% block=&quot;In the image get ball(s)' info: %status&quot;" line366="    //% status.fieldEditor=&quot;gridpicker&quot;" line367="    //% status.fieldOptions.columns=3" line368="    //% group=&quot;Ball&quot; weight=80 " line369="    //% color=#00B1ED" line370="    export function ballData(status: Ballstatus): number {" line371="        if (DataBuff[0] == 7) {" line372="            switch (status) {" line373="                case Ballstatus.X:" line374="                    return DataBuff[2]" line375="                    break" line376="                case Ballstatus.Y:" line377="                    return DataBuff[3]" line378="                    break" line379="                case Ballstatus.Size:" line380="                    return DataBuff[4]" line381="                    break" line382="                case Ballstatus.Confidence:" line383="                    return 100 - DataBuff[6]" line384="                    break" line385="                case Ballstatus.ID:" line386="                    return DataBuff[8]" line387="                    break" line388="                default:" line389="                    return 0;" line390="            }" line391="        }" line392="        else {" line393="            return 0" line394="        }" line395="    }" line396="" line397="" line398="    /**" line399="    * TODO: Judge whether there is a face in the picture" line400="    */" line401="    //% block=&quot;Image contains a face&quot;" line402="    //% group=&quot;Face&quot; weight=75 " line403="    //% color=#00B1ED" line404="    export function checkFace(): boolean {" line405="        return DataBuff[0] == 6" line406="    }" line407="    //% block=&quot;In the image get face(s)' total&quot;" line408="    //% group=&quot;Face&quot; weight=74 " line409="    //% color=#00B1ED" line410="    export function faceTotalNum(): number {" line411="        if (DataBuff[0] == 6) {" line412="            return DataBuff[7]" line413="        }" line414="        else {" line415="            return 0" line416="        }" line417="    }" line418="    /**" line419="    * TODO: Judge whether there is a face in the picture" line420="    * @param status Facestatus, eg: Facestatus.X" line421="    */" line422="    //% block=&quot;In the image get face(s)' info: %status&quot;" line423="    //% status.fieldEditor=&quot;gridpicker&quot;" line424="    //% status.fieldOptions.columns=3" line425="    //% group=&quot;Face&quot; weight=70 " line426="    //% color=#00B1ED" line427="    export function faceData(status: Facestatus): number {" line428="        if (DataBuff[0] == 6) {" line429="            switch (status) {" line430="                case Facestatus.X:" line431="                    return DataBuff[2]" line432="                    break" line433="                case Facestatus.Y:" line434="                    return DataBuff[3]" line435="                    break" line436="                case Facestatus.W:" line437="                    return DataBuff[4]" line438="                    break" line439="                case Facestatus.H:" line440="                    return DataBuff[5]" line441="                    break" line442="                case Facestatus.Confidence:" line443="                    return 100 - DataBuff[6]" line444="                    break" line445="                case Facestatus.ID:" line446="                    return DataBuff[8]" line447="                    break" line448="                default:" line449="                    return 0" line450="            }" line451="        }" line452="        else {" line453="            return 0" line454="        }" line455="    }" line456="    /**" line457="    * TODO: Judge whether there is a digital card in the screen" line458="    * @param status numberCards, eg: numberCards.1" line459="    */" line460="    //% block=&quot;Image contains number card(s): %status&quot;" line461="    //% status.fieldEditor=&quot;gridpicker&quot;" line462="    //% status.fieldOptions.columns=3" line463="    //% group=&quot;Card&quot; weight=65 " line464="    //% color=#00B1ED" line465="    export function numberCard(status: numberCards): boolean {" line466="        if (DataBuff[0] == 2) {" line467="            return status == DataBuff[1]" line468="        }" line469="        else" line470="            return false" line471="    }" line472="    /**" line473="    * TODO: Judge whether there is a letter card in the screen" line474="    * @param status letterCards, eg: letterCards.A" line475="    */" line476="    //% block=&quot;Image contains letter card(s): %status&quot;" line477="    //% status.fieldEditor=&quot;gridpicker&quot;" line478="    //% status.fieldOptions.columns=3" line479="    //% group=&quot;Card&quot; weight=60 " line480="    //% color=#00B1ED" line481="    export function letterCard(status: letterCards): boolean {" line482="        if (DataBuff[0] == 4) {" line483="            return status == DataBuff[1]" line484="        }" line485="        else" line486="            return false" line487="    }" line488="    /**" line489="    * TODO: Judge whether there is a traffic card in the screen" line490="    * @param status trafficCards, eg: trafficCards.forward" line491="    */" line492="    //% block=&quot;Image contains traffic card(s): %status&quot;" line493="    //% status.fieldEditor=&quot;gridpicker&quot;" line494="    //% status.fieldOptions.columns=3" line495="    //% group=&quot;Card&quot; weight=55 " line496="    //% color=#00B1ED" line497="    export function trafficCard(status: trafficCards): boolean {" line498="        if (DataBuff[0] == 3) {" line499="            return status == DataBuff[1]" line500="        }" line501="        else" line502="            return false" line503="    }" line504="    /**" line505="    * TODO: Judge whether there is a other card in the screen" line506="    * @param status otherCards, eg: otherCards.cat" line507="    */" line508="    //% block=&quot;Image contains other card(s): %status&quot;" line509="    //% status.fieldEditor=&quot;gridpicker&quot;" line510="    //% status.fieldOptions.columns=3" line511="    //% group=&quot;Card&quot; " line512="    //% color=#00B1ED" line513="    export function otherCard(status: otherCards): boolean {" line514="        if (DataBuff[0] == 3) {" line515="            return status == DataBuff[1]" line516="        }" line517="        else" line518="            return false" line519="    }" line520="    //% block=&quot;In the image get Card(s)' total&quot;" line521="    //% group=&quot;Card&quot; weight=49 " line522="    //% color=#00B1ED" line523="    export function cardTotalNum(): number {" line524="        if (DataBuff[0] == 2 || DataBuff[0] == 3 || DataBuff[0] == 4) {" line525="            return DataBuff[7]" line526="        }" line527="        else {" line528="            return 0" line529="        }" line530="    }" line531="    /**" line532="    * TODO: Card parameters in the screen" line533="    * @param status otherCards, eg: Cardstatus.X" line534="    */" line535="    //% block=&quot;In the image get Card(s)' info: %status&quot;" line536="    //% status.fieldEditor=&quot;gridpicker&quot;" line537="    //% status.fieldOptions.columns=3" line538="    //% group=&quot;Card&quot; weight=45 " line539="    //% color=#00B1ED" line540="    export function CardData(status: Cardstatus): number {" line541="        if (DataBuff[0] == 2 || DataBuff[0] == 3 || DataBuff[0] == 4) {" line542="            switch (status) {" line543="                case Cardstatus.X:" line544="                    return DataBuff[2]" line545="                    break" line546="                case Cardstatus.Y:" line547="                    return DataBuff[3]" line548="                    break" line549="                case Cardstatus.Size:" line550="                    return DataBuff[4]" line551="                    break" line552="                case Cardstatus.Confidence:" line553="                    return 100 - DataBuff[6]" line554="                    break" line555="                case Cardstatus.ID:" line556="                    return DataBuff[8]" line557="                    break" line558="                default:" line559="                    return 0" line560="            }" line561="        }" line562="        else" line563="            return 0" line564="    }" line565="    /**" line566="    * TODO: Judge whether there is a color in the screen" line567="    * @param status ColorLs, eg: ColorLs.red" line568="    */" line569="    //% block=&quot;Image contains color card(s): %status&quot;" line570="    //% status.fieldEditor=&quot;gridpicker&quot;" line571="    //% status.fieldOptions.columns=3" line572="    //% group=&quot;Color&quot; weight=30 " line573="    //% color=#00B1ED" line574="    export function colorCheck(status: ColorLs): boolean {" line575="        if (DataBuff[0] == 9) {" line576="            return status == DataBuff[1]" line577="        }" line578="        else" line579="            return false" line580="    }" line581="    //% block=&quot;In the image get color card(s)' total&quot;" line582="    //% group=&quot;Color&quot; weight=29 " line583="    //% color=#00B1ED" line584="    export function colorTotalNum(): number {" line585="        if (DataBuff[0] == 9) {" line586="            return DataBuff[7]" line587="        }" line588="        else {" line589="            return 0" line590="        }" line591="    }" line592="    /**" line593="    * TODO: color parameters in the screen" line594="    * @param status Colorstatus, eg: Colorstatus.X" line595="    */" line596="    //% block=&quot;In the image get color card(s)' info: %status&quot;" line597="    //% status.fieldEditor=&quot;gridpicker&quot;" line598="    //% status.fieldOptions.columns=3" line599="    //% group=&quot;Color&quot; weight=25 " line600="    //% color=#00B1ED" line601="    export function colorData(status: Colorstatus): number {" line602="        if (DataBuff[0] == 9) {" line603="            switch (status) {" line604="                case Colorstatus.X:" line605="                    return DataBuff[2]" line606="                    break" line607="                case Colorstatus.Y:" line608="                    return DataBuff[3]" line609="                    break" line610="                case Colorstatus.Size:" line611="                    return DataBuff[4]" line612="                    break" line613="                case Colorstatus.Confidence:" line614="                    return 100 - DataBuff[6]" line615="                    break" line616="                case Colorstatus.ID:" line617="                    return DataBuff[8]" line618="                    break" line619="                default:" line620="                    return 0" line621="            }" line622="        }" line623="        else {" line624="            return 0" line625="        }" line626="    }" line627="    /**" line628="    * TODO: line parameters in the screen" line629="    * @param status Linestatus, eg: Linestatus.angle" line630="    */" line631="    //% block=&quot;In the image get line(s)' info: %status&quot;" line632="    //% status.fieldEditor=&quot;gridpicker&quot;" line633="    //% status.fieldOptions.columns=3" line634="    //% group=&quot;Tracking&quot;" line635="    //% weight=35 " line636="    //% color=#00B1ED" line637="    export function lineData(status: Linestatus): number {" line638="        if (DataBuff[0] == 8) {" line639="            switch (status) {" line640="                case Linestatus.angle:" line641="                    return DataBuff[1]" line642="                    break" line643="                case Linestatus.width:" line644="                    return DataBuff[2]" line645="                    break" line646="                case Linestatus.len:" line647="                    return DataBuff[3]" line648="                    break" line649="                default:" line650="                    return 0" line651="            }" line652="        }" line653="        else" line654="            return 0" line655="    }" line656="    /**" line657="    * TODO: line parameters in the screen" line658="    * @param status Linestatus, eg: Linestatus.angle" line659="    */" line660="    //% block=&quot;Image contains line's direction towards %status&quot;" line661="    //% status.fieldEditor=&quot;gridpicker&quot;" line662="    //% status.fieldOptions.columns=2" line663="    //% group=&quot;Tracking&quot;" line664="    //% weight=34 " line665="    //% color=#00B1ED" line666="    export function lineDirection(status: LineTrend): boolean {" line667="        if (DataBuff[0] == 8) {" line668="            switch (status) {" line669="                case LineTrend.none:" line670="                    return false" line671="                    break" line672="                case LineTrend.left:" line673="                    if (DataBuff[2] &lt; 90) {" line674="                        return true" line675="                    }" line676="                    else {" line677="                        return false" line678="                    }" line679="                    break" line680="                case LineTrend.right:" line681="                    if (DataBuff[2] &gt; 130) {" line682="                        return true" line683="                    }" line684="                    else {" line685="                        return false" line686="                    }" line687="                    break" line688="                case LineTrend.front:" line689="                    if (DataBuff[2] &gt; 90 &amp;&amp; DataBuff[2] &lt; 130) {" line690="                        return true" line691="                    }" line692="                    else {" line693="                        return false" line694="                    }" line695="                    break" line696="            }" line697="        }" line698="        else {" line699="            if (status == LineTrend.none)" line700="                return true" line701="        }" line702="        return false" line703="    }" line704="" line705="    /**" line706="    * TODO: Learn an object in a picture" line707="    * @param thingsID Edit a label for the object, eg: 1" line708="    */" line709="    //% block=&quot;Learn an object with: %thingsID&quot;" line710="    //% status.fieldEditor=&quot;gridpicker&quot;" line711="    //% status.fieldOptions.columns=3" line712="    //% group=&quot;Learn&quot; weight=20 " line713="    //% color=#00B1ED" line714="    export function learnObject(thingsID: learnID): void {" line715="        let thingsBuf = pins.createBuffer(9)" line716="        thingsBuf[0] = 10" line717="        thingsBuf[1] = thingsID" line718="        pins.i2cWriteBuffer(CameraAdd, thingsBuf)" line719="    }" line720="    /**" line721="    * TODO: Clear Learned Objects" line722="    */" line723="    //% block=&quot;Clear learned objects&quot;" line724="    //% group=&quot;Learn&quot; weight=15 " line725="    //% color=#00B1ED" line726="    export function ClearlearnObject(): void {" line727="        let thingsBuf2 = pins.createBuffer(9)" line728="        thingsBuf2[0] = 10" line729="        thingsBuf2[1] = 10" line730="        pins.i2cWriteBuffer(CameraAdd, thingsBuf2)" line731="    }" line732="    /**" line733="    * TODO: Judge whether there are any learned objects in the picture" line734="    */" line735="    //% block=&quot;Image contains learned objects: %status&quot;" line736="    //% status.fieldEditor=&quot;gridpicker&quot;" line737="    //% status.fieldOptions.columns=3" line738="    //% group=&quot;Learn&quot; weight=14 " line739="    //% color=#00B1ED" line740="    export function objectCheck(status: learnID): boolean {" line741="        if (DataBuff[0] == 10 &amp;&amp; status == DataBuff[1]) {" line742="            if (objectConfidence(status) &gt;= 83) {" line743="                return true" line744="            }" line745="            else {" line746="                return false" line747="            }" line748="        }" line749="        else" line750="            return false" line751="    }" line752="    /**" line753="    * TODO: Judge whether there are any learned objects in the picture" line754="    */" line755="    //% block=&quot;In the image get learn object %thingsID Confidence&quot;" line756="    //% group=&quot;Learn&quot; weight=10 " line757="    //% color=#00B1ED" line758="    export function objectConfidence(thingsID: learnID): number {" line759="        if (DataBuff[0] == 10 &amp;&amp; DataBuff[2] &lt; 30) {" line760="            if (DataBuff[1] == thingsID) {" line761="                return 100 - DataBuff[2]" line762="            }" line763="            else {" line764="                return 0" line765="            }" line766="        }" line767="        return 0" line768="    }" line769="    let asrEventId = 3500" line770="    let lastvoc = 0" line771="    //% block=&quot;ASR sensor hear %vocabulary&quot;" line772="    //% subcategory=ASR group=&quot;IIC Port&quot;" line773="    //% vocabulary.fieldEditor=&quot;gridpicker&quot; vocabulary.fieldOptions.columns=3" line774="    //% color=#00B1ED" line775="    export function onASR(vocabulary: vocabularyList, handler: () =&gt; void) {" line776="        control.onEvent(asrEventId, vocabulary, handler);" line777="        control.inBackground(() =&gt; {" line778="            while (true) {" line779="                const voc = pins.i2cReadNumber(0x0B, 1)" line780="                if (voc != lastvoc) {" line781="                    lastvoc = voc" line782="                    control.raiseEvent(asrEventId, lastvoc);" line783="                }" line784="                basic.pause(50);" line785="            }" line786="        })" line787="    }" line788="    //% block=&quot;ASR sensor enter learning-model&quot;" line789="    //% subcategory=ASR group=&quot;IIC Port&quot;" line790="    //% color=#00B1ED" line791="    export function setASRLearn(): void {" line792="        pins.i2cWriteNumber(0x0B, 0x50, NumberFormat.Int8LE)" line793="    }" line794="    //% block=&quot;ASR sensor clear learned entrys&quot;" line795="    //% subcategory=ASR group=&quot;IIC Port&quot;" line796="    //% color=#00B1ED" line797="    export function delASRLearn(): void {" line798="        pins.i2cWriteNumber(0x0B, 0x60, NumberFormat.Int8LE)" line799="    }" line800="}" numlines="801"></mutation><next><block type="typescript_statement" id="7r4n]{a[os6PC8Oi/EMM"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace GigoWorkshop {" line1="" line2="    ////////////////////////////////" line3="    //          DDM Motor         //" line4="    ////////////////////////////////" line5="" line6="" line7="    /**motor channel" line8="    A(1,2)" line9="    B(8,13)" line10="    C(14,15)" line11="    D(16,0)" line12="    I2C(20,19)" line13="    */" line14="    // motor for gigotools kit " line15="    export enum GgMotorChannel {" line16="        //% block=&quot;A (P2,P1)&quot;" line17="        A," line18="        //% block=&quot;B (P13,P8)&quot;&quot;" line19="        B," line20="        //% block=&quot;C (P15,P14)&quot;&quot;" line21="        C," line22="        //% block=&quot;D (P0,P16)&quot;&quot;" line23="        D," line24="    }" line25="    export enum GgMotorShaftDirection {" line26="        //% block=&quot;Left&quot;" line27="        LOW," line28="        //% block=&quot;Right&quot;" line29="        HIGH," line30="" line31="    }" line32="    export let GgmotorSpeedPins: { [key: number]: AnalogPin } = {" line33="        [GgMotorChannel.A]: AnalogPin.P1," line34="        [GgMotorChannel.B]: AnalogPin.P8," line35="        [GgMotorChannel.C]: AnalogPin.P14," line36="        [GgMotorChannel.D]: AnalogPin.P16," line37="    }" line38="    export let GgmotorChannels: { [key: number]: DigitalPin } = {" line39="        [GgMotorChannel.A]: DigitalPin.P2," line40="        [GgMotorChannel.B]: DigitalPin.P13," line41="        [GgMotorChannel.C]: DigitalPin.P15," line42="        [GgMotorChannel.D]: DigitalPin.P0," line43="    }" line44="" line45="    export enum GigoMotorChannel {" line46="        //% block=&quot;A&quot;" line47="        MotorA = 1," line48="        //% block=&quot;B&quot;" line49="        MotorB = 2," line50="        //% block=&quot;C&quot;" line51="        MotorC = 3," line52="        //% block=&quot;D&quot;" line53="        MotorD = 4" line54="    }" line55="" line56="" line57="" line58="    //% blockId=DDMmotor2 block=&quot;motor channel %MotorPin|speed (0~100) %MSpeedValue|rotation direction(0~1) %McontrolValue&quot; blockExternalInputs=false" line59="    //% McontrolValue.min=0 McontrolValue.max=1 " line60="    //% MSpeedValue.min=0 MSpeedValue.max=100   " line61="    //% group=&quot;Motor for workshop&quot;" line62="    export function ddmmotor2(MotorPin: GigoMotorChannel, MSpeedValue: number, McontrolValue: number): void {" line63="" line64="        switch (MotorPin) {" line65="            case 1:" line66="                pins.analogWritePin(AnalogPin.P2, pins.map(MSpeedValue, 0, 100, 0, 1000));" line67="                pins.digitalWritePin(DigitalPin.P1, pins.map(McontrolValue, 0, 1, 0, 1));" line68="                break;" line69="            case 2:" line70="                pins.analogWritePin(AnalogPin.P13, pins.map(MSpeedValue, 0, 100, 0, 1000));" line71="                pins.digitalWritePin(DigitalPin.P8, pins.map(McontrolValue, 0, 1, 0, 1));" line72="                break;" line73="            case 3:" line74="                pins.analogWritePin(AnalogPin.P15, pins.map(MSpeedValue, 0, 100, 0, 1000));" line75="                pins.digitalWritePin(DigitalPin.P14, pins.map(McontrolValue, 0, 1, 0, 1));" line76="                break;" line77="            case 4:" line78="                pins.analogWritePin(AnalogPin.P0, pins.map(MSpeedValue, 0, 100, 0, 1000));" line79="                pins.digitalWritePin(DigitalPin.P16, pins.map(McontrolValue, 0, 1, 0, 1));" line80="                break;" line81="" line82="        }" line83="    }" line84="" line85="    //% blockId=DDMmotor block=&quot;speed pin %MSpeedPin|speed (0~255) %MSpeedValue|direction pin %McontrolPin|rotation direction(0~1) %McontrolValue&quot; blockExternalInputs=false" line86="    //% McontrolValue.min=0 McontrolValue.max=1 " line87="    //% MSpeedValue.min=0 MSpeedValue.max=255   " line88="    //% MSpeedPin.fieldEditor=&quot;gridpicker&quot; MSpeedPin.fieldOptions.columns=4" line89="    //% MSpeedPin.fieldOptions.tooltips=&quot;false&quot; MSpeedPin.fieldOptions.width=&quot;300&quot;" line90="    //% McontrolPin.fieldEditor=&quot;gridpicker&quot; McontrolPin.fieldOptions.columns=4" line91="    //% McontrolPin.fieldOptions.tooltips=&quot;false&quot; McontrolPin.fieldOptions.width=&quot;300&quot;" line92="    //% group=&quot;Motor for workshop&quot;" line93="    export function ddmmotor(MSpeedPin: AnalogPin, MSpeedValue: number, McontrolPin: DigitalPin, McontrolValue: number): void {" line94="        pins.analogWritePin(MSpeedPin, pins.map(MSpeedValue, 0, 255, 0, 1020));" line95="        pins.digitalWritePin(McontrolPin, pins.map(McontrolValue, 0, 1, 0, 1));" line96="" line97="    }" line98="" line99="    //% block=&quot;motor $channel direction $direction speed $speed&quot;" line100="    //% speed.min=0 speed.max=255" line101="    //% speed.defl=100" line102="    //% direction.min=0 direction.max=1" line103="    //% group=&quot;Motor for workshop&quot;" line104="    export function motorControl3(channel: GgMotorChannel, direction: number, speed: number): void {" line105="        let dirPin = GgmotorChannels[channel];" line106="        let speedPin = GgmotorSpeedPins[channel];" line107="" line108="        pins.digitalWritePin(dirPin, direction);" line109="        pins.analogWritePin(speedPin, pins.map(speed, 0, 255, 0, 1023));" line110="    }" line111="" line112="" line113="    //% direction.defl=ggMotorShaftDirection.HIGH" line114="    //% block=&quot;stop motor $channel&quot;" line115="    //% group=&quot;Motor for workshop&quot;" line116="    export function motorStop2(channel: GgMotorChannel): void {" line117="        let dirPin2 = GgmotorChannels[channel];" line118="        let speedPin2 = GgmotorSpeedPins[channel];" line119="" line120="        pins.digitalWritePin(dirPin2, 0);" line121="        pins.analogWritePin(speedPin2, 0);" line122="    }" line123="" line124="    //% block=&quot;motor $channel direction $direction speed $speed&quot;" line125="    //% speed.min=0 speed.max=255" line126="    //% speed.defl=100" line127="    //% direction.defl=ggMotorShaftDirection.HIGH" line128="    //% group=&quot;Motor for workshop&quot;" line129="    export function motorControl4(channel: GgMotorChannel, direction: GgMotorShaftDirection, speed: number): void {" line130="        let dirPin3 = GgmotorChannels[channel];" line131="        let speedPin3 = GgmotorSpeedPins[channel];" line132="" line133="        pins.digitalWritePin(dirPin3, direction);" line134="        pins.analogWritePin(speedPin3, pins.map(speed, 0, 255, 0, 1023));" line135="    }" line136="" line137="" line138="    ////////////////////////////////" line139="    //          Ultrasound            //" line140="    ////////////////////////////////" line141="    /**" line142="     * Send a ping and get the echo time (in microseconds) as a result" line143="     * @param trig tigger pin" line144="     * @param echo echo pin" line145="     * @param unit desired conversion unit" line146="     * @param maxCmDistance maximum distance in centimeters (default is 500)" line147="     */" line148="    export enum GgsonarPort {" line149="        //% block=&quot;A [ trig(P2) echo(P1) ]&quot;" line150="        A," line151="        //% block=&quot;B [ trig(P13) echo(P8) ]&quot;" line152="        B," line153="        //% block=&quot;C [ trig(P15) echo(P14) ]&quot;" line154="        C," line155="        //% block=&quot;D [ trig(P0) echo(P16) ]&quot;" line156="        D," line157="    }" line158="    export let GgtrigChanel: { [key: number]: DigitalPin } = {" line159="        [GgsonarPort.A]: DigitalPin.P2," line160="        [GgsonarPort.B]: DigitalPin.P13," line161="        [GgsonarPort.C]: DigitalPin.P15," line162="        [GgsonarPort.D]: DigitalPin.P0," line163="    }" line164="    export let GgechoChanel: { [key: number]: DigitalPin } = {" line165="        [GgsonarPort.A]: DigitalPin.P1," line166="        [GgsonarPort.B]: DigitalPin.P8," line167="        [GgsonarPort.C]: DigitalPin.P14," line168="        [GgsonarPort.D]: DigitalPin.P16," line169="    }" line170="    //sonar" line171="    export enum PingUnitgigo {" line172="        //% block=&quot;μs&quot;" line173="        MicroSeconds," line174="        //% block=&quot;cm&quot;" line175="        Centimeters," line176="        //% block=&quot;inches&quot;" line177="        Inches" line178="    }" line179="" line180="" line181="    //% block=&quot;sonar %channel unit %unit&quot;" line182="    //% group=&quot;Ultrasonic Sensor&quot;" line183="    //% unit.defl=PingUnitgigo.Centimeters" line184="    export function pinggigo(channel: GgsonarPort, unit: PingUnitgigo, maxCmDistance = 500): number {" line185="        let trig = GgtrigChanel[channel];" line186="        let echo = GgechoChanel[channel];" line187="        // send pulse" line188="        pins.setPull(trig, PinPullMode.PullNone);" line189="        pins.digitalWritePin(trig, 0);" line190="        control.waitMicros(2);" line191="        pins.digitalWritePin(trig, 1);" line192="        control.waitMicros(10);" line193="        pins.digitalWritePin(trig, 0);" line194="" line195="        // read pulse" line196="        const d = pins.pulseIn(echo, PulseValue.High, maxCmDistance * 58);" line197="" line198="        switch (unit) {" line199="            case PingUnitgigo.Centimeters: return Math.idiv(d, 58);" line200="            case PingUnitgigo.Inches: return Math.idiv(d, 148);" line201="            default: return d;" line202="        }" line203="    }" line204="" line205="" line206="" line207="    //% blockId=sonar_ping block=&quot;trig pin %trig|echo pin %echo|unit %unit&quot;" line208="    //% group=&quot;Ultrasonic Sensor&quot;" line209="    export function ping(trig: DigitalPin, echo: DigitalPin, unit: PingUnitgigo, maxCmDistance = 500): number {" line210="        // send pulse" line211="        pins.setPull(trig, PinPullMode.PullNone);" line212="        pins.digitalWritePin(trig, 0);" line213="        control.waitMicros(2);" line214="        pins.digitalWritePin(trig, 1);" line215="        control.waitMicros(10);" line216="        pins.digitalWritePin(trig, 0);" line217="" line218="        // read pulse" line219="        const e = pins.pulseIn(echo, PulseValue.High, maxCmDistance * 58);" line220="" line221="        switch (unit) {" line222="            case PingUnitgigo.Centimeters: return Math.idiv(e, 58);" line223="            case PingUnitgigo.Inches: return Math.idiv(e, 148);" line224="            default: return e;" line225="        }" line226="    }" line227="    ////////////////////////////////" line228="    //          RGB LEDS          //" line229="    ////////////////////////////////" line230="    /**" line231="         * Create a  RGB LED Pin." line232="         */" line233="    //% blockId=&quot;RGBLED_create&quot; block=&quot;pin %pin|&quot;" line234="    //% weight=100 blockGap=8" line235="    //% trackArgs=0,2" line236="    //% blockSetVariable=RGBLED" line237="" line238="    //% group=&quot;RGB LED&quot;" line239="    export function RGBLED_create(pin: DigitalPin): HaloHd {" line240="        let RGBLED = new HaloHd();" line241="        RGBLED.buf = pins.createBuffer(1 * 3);" line242="        RGBLED.start = 0;" line243="        RGBLED._length = 1;/*LED數量*/" line244="        RGBLED.RGBLED_set_brightness(128)" line245="        RGBLED.pin = pin;" line246="        pins.digitalWritePin(RGBLED.pin, pin);" line247="        return RGBLED;" line248="    }" line249="    export class HaloHd {" line250="        buf: Buffer;" line251="        pin: DigitalPin;" line252="        brightness: number;" line253="        start: number;" line254="        _length: number;" line255="" line256="" line257="" line258="" line259="" line260="        /**" line261="         * Shows whole ZIP Halo display as a given color (range 0-255 for r, g, b). " line262="         * @param rgb RGB color of the LED" line263="         */" line264="" line265="        //% group=&quot;RGB LED&quot;" line266="        //% block=&quot;%RGBLED|show color %rgb=RGBLED_colors&quot; " line267="        //% weight=99 blockGap=8" line268="        RGBLED_set_color(rgb: number) {" line269="            rgb = rgb &gt;&gt; 0;" line270="            this.setAllRGB(rgb);" line271="            this.show();" line272="        }" line273="" line274="" line275="" line276="        /**" line277="         * Send all the changes to the ZIP Halo display." line278="         */" line279="" line280="        //% group=&quot;RGB LED&quot;" line281="        /* blockId=&quot;kitronik_halo_hd_display_show&quot; block=&quot;%RGBLED|show&quot; blockGap=8 */" line282="        //% weight=96" line283="        show() {" line284="            //use the Kitronik version which respects brightness for all " line285="            //ws2812b.sendBuffer(this.buf, this.pin, this.brightness);" line286="            // Use the pxt-microbit core version which now respects brightness (10/2020)" line287="            light.sendWS2812BufferWithBrightness(this.buf, this.pin, this.brightness);" line288="        }" line289="" line290="        /**" line291="         * Turn off all LEDs on the ZIP Halo display." line292="         * You need to call ``show`` to make the changes visible." line293="         */" line294="" line295="        //% group=&quot;RGB LED&quot;" line296="        /* blockId=&quot;kitronik_halo_hd_display_clear&quot; block=&quot;%RGBLED|clear&quot; */" line297="        //% weight=95 blockGap=8" line298="        clear(): void {" line299="            this.buf.fill(0, this.start * 3, this._length * 3);" line300="        }" line301="" line302="        /**" line303="         * Set the brightness of the ZIP Halo display. This flag only applies to future show operation." line304="         * @param brightness a measure of LED brightness in 0-255. eg: 255" line305="         */" line306="" line307="        //% group=&quot;RGB LED&quot;" line308="        //% block=&quot;%RGBLED|set brightness %brightness&quot; blockGap=8" line309="        //% weight=92" line310="        //% brightness.min=0 brightness.max=255" line311="        RGBLED_set_brightness(brightness: number): void {" line312="            //Clamp incoming variable at 0-255 as values out of this range cause unexpected brightnesses as the lower level code only expects a byte." line313="            if (brightness &lt; 0) {" line314="                brightness = 0" line315="            }" line316="            else if (brightness &gt; 255) {" line317="                brightness = 255" line318="            }" line319="            this.brightness = brightness &amp; 0xff;" line320="            basic.pause(1) //add a pause to stop wierdnesses" line321="        }" line322="" line323="        //Sets up the buffer for pushing LED control data out to LEDs" line324="        private setBufferRGB(offset: number, red: number, green: number, blue: number): void {" line325="            this.buf[offset + 0] = green;" line326="            this.buf[offset + 1] = red;" line327="            this.buf[offset + 2] = blue;" line328="        }" line329="" line330="        //Separates out Red, Green and Blue data and fills the LED control data buffer for all LEDs" line331="        private setAllRGB(rgb: number) {" line332="            let red = unpackR(rgb);" line333="            let green = unpackG(rgb);" line334="            let blue = unpackB(rgb);" line335="" line336="            const end = this.start + this._length;" line337="            for (let i = this.start; i &lt; end; ++i) {" line338="                this.setBufferRGB(i * 3, red, green, blue)" line339="            }" line340="        }" line341="" line342="        //Separates out Red, Green and Blue data and fills the LED control data buffer for a single LED" line343="        private setPixelRGB(pixeloffset: number, rgb: number): void {" line344="            if (pixeloffset &lt; 0" line345="                || pixeloffset &gt;= this._length)" line346="                return;" line347="" line348="            pixeloffset = (pixeloffset + this.start) * 3;" line349="" line350="            let red2 = unpackR(rgb);" line351="            let green2 = unpackG(rgb);" line352="            let blue2 = unpackB(rgb);" line353="" line354="            this.setBufferRGB(pixeloffset, red2, green2, blue2)" line355="        }" line356="    }" line357="" line358="" line359="" line360="    /**" line361="     * Converts wavelength value to red, green, blue channels" line362="     * @param wavelength value between 470 and 625. eg: 500" line363="     */" line364="    //% group=&quot;RGB LED&quot;" line365="" line366="    //% weight=1 blockGap=8" line367="    /* blockId=&quot;kitronik_halo_hd_wavelength&quot; block=&quot;wavelength %wavelength|nm&quot; */" line368="    //% wavelength.min=470 wavelength.max=625" line369="    export function wavelength(wavelength: number): number {" line370="        /*  The LEDs we are using have centre wavelengths of 470nm (Blue) 525nm(Green) and 625nm (Red) " line371="        * &#9; We blend these linearly to give the impression of the other wavelengths. " line372="        *   as we cant wavelength shift an actual LED... (Ye canna change the laws of physics Capt)*/" line373="        let r = 0;" line374="        let g = 0;" line375="        let b = 0;" line376="        if ((wavelength &gt;= 470) &amp;&amp; (wavelength &lt; 525)) {" line377="            //We are between Blue and Green so mix those" line378="            g = pins.map(wavelength, 470, 525, 0, 255);" line379="            b = pins.map(wavelength, 470, 525, 255, 0);" line380="        }" line381="        else if ((wavelength &gt;= 525) &amp;&amp; (wavelength &lt;= 625)) {" line382="            //we are between Green and Red, so mix those" line383="            r = pins.map(wavelength, 525, 625, 0, 255);" line384="            g = pins.map(wavelength, 525, 625, 255, 0);" line385="        }" line386="        return packRGB(r, g, b);" line387="    }" line388="" line389="    /**" line390="     * Converts hue (0-360) to an RGB value. " line391="     * Does not attempt to modify luminosity or saturation. " line392="     * Colours end up fully saturated. " line393="     * @param hue value between 0 and 360" line394="     */" line395="" line396="    //% group=&quot;RGB LED&quot;" line397="    //% weight=1 blockGap=8" line398="    /* blockId=&quot;kitronik_halo_hd_hue&quot; block=&quot;hue %hue&quot; */" line399="    //% hue.min=0 hue.max=360" line400="    export function hueToRGB(hue: number): number {" line401="        let redVal = 0" line402="        let greenVal = 0" line403="        let blueVal = 0" line404="        let hueStep = 2.125" line405="        if ((hue &gt;= 0) &amp;&amp; (hue &lt; 120)) { //RedGreen section" line406="            greenVal = Math.floor((hue) * hueStep)" line407="            redVal = 255 - greenVal" line408="        }" line409="        else if ((hue &gt;= 120) &amp;&amp; (hue &lt; 240)) { //GreenBlueSection" line410="            blueVal = Math.floor((hue - 120) * hueStep)" line411="            greenVal = 255 - blueVal" line412="        }" line413="        else if ((hue &gt;= 240) &amp;&amp; (hue &lt; 360)) { //BlueRedSection" line414="            redVal = Math.floor((hue - 240) * hueStep)" line415="            blueVal = 255 - redVal" line416="        }" line417="        return ((redVal &amp; 0xFF) &lt;&lt; 16) | ((greenVal &amp; 0xFF) &lt;&lt; 8) | (blueVal &amp; 0xFF);" line418="    }" line419="" line420="    /*  The LEDs we are using have centre wavelengths of 470nm (Blue) 525nm(Green) and 625nm (Red) " line421="    * &#9; We blend these linearly to give the impression of the other wavelengths. " line422="    *   as we cant wavelength shift an actual LED... (Ye canna change the laws of physics Capt)*/" line423="" line424="    /**" line425="     * Converts value to red, green, blue channels" line426="     * @param red value of the red channel between 0 and 255. eg: 255" line427="     * @param green value of the green channel between 0 and 255. eg: 255" line428="     * @param blue value of the blue channel between 0 and 255. eg: 255" line429="     */" line430="" line431="    //% group=&quot;RGB LED&quot;" line432="    //% weight=1 blockGap=8" line433="    //% blockId=&quot;rgb&quot; block=&quot;red %red|green %green|blue %blue&quot;" line434="    export function rgb(red: number, green: number, blue: number): number {" line435="        return packRGB(red, green, blue);" line436="    }" line437="" line438="    /**" line439="     * Gets the RGB value of a known color" line440="    */" line441="    export enum RGBLedColors {" line442="        //% block=off" line443="        Off = 0x000000," line444="        //% block=red" line445="        Red = 0xFF0000," line446="        //% block=orange" line447="        Orange = 0xFFA500," line448="        //% block=yellow" line449="        Yellow = 0xFFFF00," line450="        //% block=green" line451="        Green = 0x00FF00," line452="        //% block=blue" line453="        Blue = 0x0000FF," line454="        //% block=indigo" line455="        Indigo = 0x4b0082," line456="        //% block=purple" line457="        Purple = 0xFF00FF," line458="        //% block=white" line459="        White = 0xFFFFFF" line460="" line461="    }" line462="" line463="    //% group=&quot;RGB LED&quot;" line464="    //% weight=2 blockGap=8" line465="    //% blockId=&quot;RGBLED_colors&quot; block=&quot;%color&quot; " line466="    export function colors(color: RGBLedColors): number {" line467="        return color;" line468="    }" line469="" line470="    //Combines individual RGB settings to be a single number" line471="    function packRGB(a: number, b: number, c: number): number {" line472="        return ((a &amp; 0xFF) &lt;&lt; 16) | ((b &amp; 0xFF) &lt;&lt; 8) | (c &amp; 0xFF);" line473="    }" line474="    //Separates red value from combined number" line475="    function unpackR(rgb: number): number {" line476="        let s = (rgb &gt;&gt; 16) &amp; 0xFF;" line477="        return s;" line478="    }" line479="    //Separates green value from combined number" line480="    function unpackG(rgb: number): number {" line481="        let h = (rgb &gt;&gt; 8) &amp; 0xFF;" line482="        return h;" line483="    }" line484="    //Separates blue value from combined number" line485="    function unpackB(rgb: number): number {" line486="        let c = (rgb) &amp; 0xFF;" line487="        return c;" line488="    }" line489="" line490="    /**" line491="     * Converts a hue saturation luminosity value into a RGB color" line492="     */" line493="    function hsl(h: number, s: number, l: number): number {" line494="        h = Math.round(h);" line495="        s = Math.round(s);" line496="        l = Math.round(l);" line497="" line498="        h = h % 360;" line499="        s = Math.clamp(0, 99, s);" line500="        l = Math.clamp(0, 99, l);" line501="        let f = Math.idiv((((100 - Math.abs(2 * l - 100)) * s) &lt;&lt; 8), 10000); //chroma, [0,255]" line502="        let h1 = Math.idiv(h, 60);//[0,6]" line503="        let h2 = Math.idiv((h - h1 * 60) * 256, 60);//[0,255]" line504="        let temp = Math.abs((((h1 % 2) &lt;&lt; 8) + h2) - 256);" line505="        let x = (f * (256 - (temp))) &gt;&gt; 8;//[0,255], second largest component of this color" line506="        let r$: number;" line507="        let g$: number;" line508="        let b$: number;" line509="        if (h1 == 0) {" line510="            r$ = f; g$ = x; b$ = 0;" line511="        } else if (h1 == 1) {" line512="            r$ = x; g$ = f; b$ = 0;" line513="        } else if (h1 == 2) {" line514="            r$ = 0; g$ = f; b$ = x;" line515="        } else if (h1 == 3) {" line516="            r$ = 0; g$ = x; b$ = f;" line517="        } else if (h1 == 4) {" line518="            r$ = x; g$ = 0; b$ = f;" line519="        } else if (h1 == 5) {" line520="            r$ = f; g$ = 0; b$ = x;" line521="        }" line522="        let m = Math.idiv((Math.idiv((l * 2 &lt;&lt; 8), 100) - f), 2);" line523="        let t = r$ + m;" line524="        let j = g$ + m;" line525="        let k = b$ + m;" line526="        return packRGB(t, j, k);" line527="    }" line528="" line529="    /**" line530="     * Options for direction hue changes, used by rainbow block (never visible to end user)" line531="     */" line532="    export enum HueInterpolationDirection {" line533="        Clockwise," line534="        CounterClockwise," line535="        Shortest" line536="    }" line537="" line538="    ////////////////////////////////" line539="    //          Colour sensor       //" line540="    ////////////////////////////////" line541="    //% weight=12" line542="    //% block=&quot;initialize color sensor&quot;" line543="" line544="    //% group=&quot;Color Sensor&quot;" line545="    export function colorSensorinit(): void {" line546="        pins.i2cWriteNumber(41, 33276, NumberFormat.UInt16BE, false)" line547="        pins.i2cWriteNumber(41, 32771, NumberFormat.UInt16BE, false)" line548="    }" line549="    /**" line550="    */" line551="    let nowReadColor = [0, 0, 0]" line552="    //% weight=12" line553="    //% block=&quot;color sensor read color&quot;" line554="" line555="    //% group=&quot;Color Sensor&quot;" line556="    export function colorSensorReadColor(): void {" line557="        pins.i2cWriteNumber(41, 178, NumberFormat.Int8LE, false)" line558="" line559="        pins.i2cWriteNumber(41, 179, NumberFormat.Int8LE, false)" line560="" line561="        pins.i2cWriteNumber(41, 182, NumberFormat.Int8LE, true)" line562="        let TCS_RED = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line563="        pins.i2cWriteNumber(41, 184, NumberFormat.Int8LE, true)" line564="        let TCS_GREEN = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line565="        pins.i2cWriteNumber(41, 186, NumberFormat.Int8LE, true)" line566="        let TCS_BLUE = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line567="        TCS_RED = Math.round(Math.map(TCS_RED, 0, 65535, 0, 255))" line568="        TCS_GREEN = Math.round(Math.map(TCS_GREEN, 0, 65535, 0, 255))" line569="        TCS_BLUE = Math.round(Math.map(TCS_BLUE, 0, 65535, 0, 255))" line570="        nowReadColor = [TCS_RED, TCS_GREEN, TCS_BLUE]" line571="    }" line572="    /**" line573="   */" line574="    export enum Channel {" line575="        //% block=&quot;R&quot;" line576="        Red = 1," line577="        //% block=&quot;G&quot;" line578="        Green = 2," line579="        //% block=&quot;B&quot;" line580="        Blue = 3" line581="    }" line582="    //% weight=12" line583="    //% block=&quot;color sensor read RGB %channel |channel&quot;" line584="" line585="    //% group=&quot;Color Sensor&quot;" line586="    export function colorSensorRead(channel: Channel = 1): number {" line587="        pins.i2cWriteNumber(41, 178, NumberFormat.Int8LE, false)" line588="" line589="        pins.i2cWriteNumber(41, 179, NumberFormat.Int8LE, false)" line590="" line591="        pins.i2cWriteNumber(41, 182, NumberFormat.Int8LE, true)" line592="        let TCS_RED2 = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line593="        pins.i2cWriteNumber(41, 184, NumberFormat.Int8LE, true)" line594="        let TCS_GREEN2 = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line595="        pins.i2cWriteNumber(41, 186, NumberFormat.Int8LE, true)" line596="        let TCS_BLUE2 = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line597="" line598="        let RdCl = 0" line599="        switch (channel) {" line600="            case 1:" line601="                RdCl = Math.round(Math.map(TCS_RED2, 0, 65535, 0, 255))" line602="                break;" line603="            case 2:" line604="                RdCl = Math.round(Math.map(TCS_GREEN2, 0, 65535, 0, 255))" line605="                break;" line606="            case 3:" line607="                RdCl = Math.round(Math.map(TCS_BLUE2, 0, 65535, 0, 255))" line608="                break;" line609="        }" line610="" line611="        return RdCl" line612="    }" line613="    export enum ColorPart {" line614="        //% block=&quot;Red&quot;" line615="        Red = 1," line616="        //% block=&quot;Green&quot;" line617="        Green = 2," line618="        //% block=&quot;Blue&quot;" line619="        Blue = 3," line620="        //% block=&quot;Yellow&quot;" line621="        Yellow = 4," line622="        //% block=&quot;Purple&quot;" line623="        Purple = 5," line624="        //% block=&quot;Custom1&quot;" line625="        Custom1 = 6," line626="        //% block=&quot;Custom2&quot;" line627="        Custom2 = 7," line628="        //% block=&quot;Custom3&quot;" line629="        Custom3 = 8" line630="    }" line631="" line632="    let ReadRedColor = [0, 0, 0]" line633="    let ReadGreenColor = [0, 0, 0]" line634="    let ReadBlueColor = [0, 0, 0]" line635="    let ReadYellowColor = [0, 0, 0]" line636="    let ReadPurpleColor = [0, 0, 0]" line637="    let ReadCustom1Color = [0, 0, 0]" line638="    let ReadCustom2Color = [0, 0, 0]" line639="    let ReadCustom3Color = [0, 0, 0]" line640="" line641="    //% weight=12" line642="    //% block=&quot;color sensor record %colorpart |&quot;" line643="" line644="    //% group=&quot;Color Sensor&quot;" line645="    export function colorSensorRecord(colorpart: ColorPart = 1): void {" line646="        pins.i2cWriteNumber(41, 178, NumberFormat.Int8LE, false)" line647="" line648="        pins.i2cWriteNumber(41, 179, NumberFormat.Int8LE, false)" line649="" line650="        pins.i2cWriteNumber(41, 182, NumberFormat.Int8LE, true)" line651="        let TCS_RED3 = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line652="        pins.i2cWriteNumber(41, 184, NumberFormat.Int8LE, true)" line653="        let TCS_GREEN3 = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line654="        pins.i2cWriteNumber(41, 186, NumberFormat.Int8LE, true)" line655="        let TCS_BLUE3 = pins.i2cReadNumber(41, NumberFormat.UInt16BE, false)" line656="        TCS_RED3 = Math.round(Math.map(TCS_RED3, 0, 65535, 0, 255))" line657="        TCS_GREEN3 = Math.round(Math.map(TCS_GREEN3, 0, 65535, 0, 255))" line658="        TCS_BLUE3 = Math.round(Math.map(TCS_BLUE3, 0, 65535, 0, 255))" line659="        switch (colorpart) {" line660="            case 1:" line661="                ReadRedColor = [TCS_RED3, TCS_GREEN3, TCS_BLUE3]" line662="                break;" line663="            case 2:" line664="                ReadGreenColor = [TCS_RED3, TCS_GREEN3, TCS_BLUE3]" line665="                break;" line666="            case 3:" line667="                ReadBlueColor = [TCS_RED3, TCS_GREEN3, TCS_BLUE3]" line668="                break;" line669="            case 4:" line670="                ReadYellowColor = [TCS_RED3, TCS_GREEN3, TCS_BLUE3]" line671="                break;" line672="            case 5:" line673="                ReadPurpleColor = [TCS_RED3, TCS_GREEN3, TCS_BLUE3]" line674="                break;" line675="            case 6:" line676="                ReadCustom1Color = [TCS_RED3, TCS_GREEN3, TCS_BLUE3]" line677="                break;" line678="            case 7:" line679="                ReadCustom2Color = [TCS_RED3, TCS_GREEN3, TCS_BLUE3]" line680="                break;" line681="            case 8:" line682="                ReadCustom3Color = [TCS_RED3, TCS_GREEN3, TCS_BLUE3]" line683="                break;" line684="        }" line685="    }" line686="    let WriteRedColor = [0, 0, 0]" line687="    let WriteGreenColor = [0, 0, 0]" line688="    let WriteBlueColor = [0, 0, 0]" line689="    let WriteYellowColor = [0, 0, 0]" line690="    let WritePurpleColor = [0, 0, 0]" line691="    let WriteCustom1Color = [0, 0, 0]" line692="    let WriteCustom2Color = [0, 0, 0]" line693="    let WriteCustom3Color = [0, 0, 0]" line694="    let colorright = false" line695="    let forkrange = 5" line696="    //% weight=99 blockGap=8" line697="    //% block=&quot;read R %WriteRed|and G %WriteGreen|and B %WriteBlue equal to %colorpart|&quot;" line698="    //% WriteRed.min=0 WriteRed.max=255" line699="    //% WriteGreen.min=0 WriteGreen.max=255" line700="    //% WriteBlue.min=0 WriteBlue.max=255" line701="" line702="    //% group=&quot;Color Sensor&quot;" line703="    export function readColorEqual(WriteRed: number, WriteGreen: number, WriteBlue: number, colorpart: ColorPart = 1): boolean {" line704="        switch (colorpart) {" line705="            case 1:" line706="                WriteRedColor = [WriteRed, WriteGreen, WriteBlue];" line707="                if ((Math.abs(ReadRedColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(ReadRedColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(ReadRedColor[2] - nowReadColor[2]) &lt; forkrange)) {" line708="                    colorright = true" line709="                }" line710="                else if ((Math.abs(WriteRedColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(WriteRedColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(WriteRedColor[2] - nowReadColor[2]) &lt; forkrange)) {" line711="                    colorright = true" line712="                }" line713="                else {" line714="                    colorright = false" line715="                }" line716="                break;" line717="            case 2:" line718="                WriteGreenColor = [WriteRed, WriteGreen, WriteBlue];" line719="                if ((Math.abs(ReadGreenColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(ReadGreenColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(ReadGreenColor[2] - nowReadColor[2]) &lt; forkrange)) {" line720="                    colorright = true" line721="                }" line722="                else if ((Math.abs(WriteGreenColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(WriteGreenColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(WriteGreenColor[2] - nowReadColor[2]) &lt; forkrange)) {" line723="                    colorright = true" line724="                }" line725="                else {" line726="                    colorright = false" line727="                }" line728="                break;" line729="            case 3:" line730="                WriteBlueColor = [WriteRed, WriteGreen, WriteBlue];" line731="                if ((Math.abs(ReadBlueColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(ReadBlueColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(ReadBlueColor[2] - nowReadColor[2]) &lt; forkrange)) {" line732="                    colorright = true" line733="                }" line734="                else if ((Math.abs(WriteBlueColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(WriteBlueColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(WriteBlueColor[2] - nowReadColor[2]) &lt; forkrange)) {" line735="                    colorright = true" line736="                }" line737="                else {" line738="                    colorright = false" line739="                }" line740="                break;" line741="            case 4:" line742="                WriteYellowColor = [WriteRed, WriteGreen, WriteBlue];" line743="                if ((Math.abs(ReadYellowColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(ReadYellowColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(ReadYellowColor[2] - nowReadColor[2]) &lt; forkrange)) {" line744="                    colorright = true" line745="                }" line746="                else if ((Math.abs(WriteYellowColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(WriteYellowColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(WriteYellowColor[2] - nowReadColor[2]) &lt; forkrange)) {" line747="                    colorright = true" line748="                }" line749="                else {" line750="                    colorright = false" line751="                }" line752="                break;" line753="" line754="            case 5:" line755="                WritePurpleColor = [WriteRed, WriteGreen, WriteBlue];" line756="                if ((Math.abs(ReadPurpleColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(ReadPurpleColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(ReadPurpleColor[2] - nowReadColor[2]) &lt; forkrange)) {" line757="                    colorright = true" line758="                }" line759="                else if ((Math.abs(WritePurpleColor[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(WritePurpleColor[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(WritePurpleColor[2] - nowReadColor[2]) &lt; forkrange)) {" line760="                    colorright = true" line761="                }" line762="                else {" line763="                    colorright = false" line764="                }" line765="                break;" line766="            case 6:" line767="                WriteCustom1Color = [WriteRed, WriteGreen, WriteBlue];" line768="                if ((Math.abs(ReadCustom1Color[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(ReadCustom1Color[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(ReadCustom1Color[2] - nowReadColor[2]) &lt; forkrange)) {" line769="                    colorright = true" line770="                }" line771="                else if ((Math.abs(WriteCustom1Color[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(WriteCustom1Color[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(WriteCustom1Color[2] - nowReadColor[2]) &lt; forkrange)) {" line772="                    colorright = true" line773="                }" line774="                else {" line775="                    colorright = false" line776="                }" line777="                break;" line778="            case 7:" line779="                WriteCustom2Color = [WriteRed, WriteGreen, WriteBlue];" line780="                if ((Math.abs(ReadCustom2Color[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(ReadCustom2Color[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(ReadCustom2Color[2] - nowReadColor[2]) &lt; forkrange)) {" line781="                    colorright = true" line782="                }" line783="                else if ((Math.abs(WriteCustom2Color[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(WriteCustom2Color[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(WriteCustom2Color[2] - nowReadColor[2]) &lt; forkrange)) {" line784="                    colorright = true" line785="                }" line786="                else {" line787="                    colorright = false" line788="                }" line789="                break;" line790="            case 8:" line791="                WriteCustom3Color = [WriteRed, WriteGreen, WriteBlue];" line792="                if ((Math.abs(ReadCustom3Color[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(ReadCustom3Color[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(ReadCustom3Color[2] - nowReadColor[2]) &lt; forkrange)) {" line793="                    colorright = true" line794="                }" line795="                else if ((Math.abs(WriteCustom3Color[0] - nowReadColor[0]) &lt; forkrange) &amp;&amp; (Math.abs(WriteCustom3Color[1] - nowReadColor[1]) &lt; forkrange) &amp;&amp; (Math.abs(WriteCustom3Color[2] - nowReadColor[2]) &lt; forkrange)) {" line796="                    colorright = true" line797="                }" line798="                else {" line799="                    colorright = false" line800="                }" line801="                break;" line802="        }" line803="        if (colorright == true) {" line804="            return true" line805="        }" line806="        else {" line807="            return false" line808="        }" line809="    }" line810="" line811="}" numlines="812"></mutation><next><block type="typescript_statement" id="6,s@,@.9:4$IH8DXQlBX"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace GigoLED {" line1="    //----------------------------------" line2="    //led" line3="    export enum LEDChannel {" line4="        //% block=&quot;A (P19)&quot;" line5="        A," line6="        //% block=&quot;B (P14)&quot;" line7="        B," line8="        //% block=&quot;C (P2)&quot;" line9="        C," line10="        //% block=&quot;D (P8)&quot;" line11="        D," line12="        //% block=&quot;E (P15)&quot;" line13="        E," line14="        //% block=&quot;F (P13)&quot;" line15="        F," line16="        //% block=&quot;G (P12)&quot;" line17="        G," line18="        //% block=&quot;H (P1)&quot;" line19="        H," line20="    }" line21="    export let LEDChannels: { [key: number]: DigitalPin } = {" line22="        [LEDChannel.A]: DigitalPin.P19," line23="        [LEDChannel.B]: DigitalPin.P14," line24="        [LEDChannel.C]: DigitalPin.P2," line25="        [LEDChannel.D]: DigitalPin.P8," line26="        [LEDChannel.E]: DigitalPin.P15," line27="        [LEDChannel.F]: DigitalPin.P13," line28="        [LEDChannel.G]: DigitalPin.P12," line29="        [LEDChannel.H]: DigitalPin.P1," line30="    }" line31="    export enum LEDShaftonoff {" line32="        //% block=&quot;off&quot;" line33="        LOW," line34="        //% block=&quot;on&quot;" line35="        HIGH," line36="" line37="    }" line38="    //----------------------------------" line39="    //% color=#FACB09" line40="    //% block=&quot;led $leds status $status&quot;" line41="    //% status.min=0 status.max=1" line42="    //% leds.defl=lEDChannel.D" line43="    //% group=&quot;Led&quot;" line44="    export function ledtest(leds: LEDChannel, status: number): void {" line45="        let ledg = LEDChannels[leds];" line46="        pins.digitalWritePin(ledg, status);" line47="" line48="    }" line49="" line50="    //% color=#FACB09" line51="    //% block=&quot;led $leds status $status&quot;" line52="    //% status.defl=lEDShaftonoff.HIGH*" line53="    //% leds.defl=lEDChannel.D" line54="    //% group=&quot;Led&quot;" line55="    export function led(leds: LEDChannel, status: LEDShaftonoff): void {" line56="        let ledg2 = LEDChannels[leds];" line57="        pins.digitalWritePin(ledg2, status);" line58="" line59="    }" line60="    //% color=#FACB09" line61="    //toggle led" line62="    //% blockId=led block=&quot;led %pin $ledstate&quot;" line63="    //% ledstate.shadow=&quot;toggleOnOff&quot;" line64="    //% expandableArgumentMode=&quot;toggle&quot;" line65="    //% pin.defl=lEDChannel.D" line66="    //% group=&quot;Led&quot;" line67="    export function ledBrightness(pin: LEDChannel, ledstate: boolean): void {" line68="        if (ledstate) {" line69="            let pinled = LEDChannels[pin];" line70="            pins.digitalWritePin(pinled, 1);" line71="" line72="        }" line73="        else {" line74="            let pinled2 = LEDChannels[pin];" line75="            pins.digitalWritePin(pinled2, 0);" line76="" line77="        }" line78="    }" line79="}" numlines="80"></mutation><next><block type="typescript_statement" id="T?$l8=zSKXnzb;#YDC7]"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace GigoSensor {" line1="    //external button" line2="    export enum ButtonChannel {" line3="        //% block=&quot;A (P20)&quot;" line4="        A," line5="        //% block=&quot;E (P16)&quot;" line6="        E," line7="        //% block=&quot;F (P14)&quot;" line8="        F," line9="        //% block=&quot;G (P2)&quot;" line10="        G," line11="        //% block=&quot;H (P8)&quot;" line12="        H," line13="    }" line14="    export let ButtonChannels: { [key: number]: DigitalPin } = {" line15="        [ButtonChannel.A]: DigitalPin.P20," line16="        [ButtonChannel.E]: DigitalPin.P16," line17="        [ButtonChannel.F]: DigitalPin.P14," line18="        [ButtonChannel.G]: DigitalPin.P2," line19="        [ButtonChannel.H]: DigitalPin.P8," line20="" line21="    }" line22="    //----------------------------------" line23="" line24="" line25="" line26="    //external sensor" line27="    export enum SensorChannel {" line28="        //% block=&quot;P1&quot;" line29="        P1," line30="        //% block=&quot;P8&quot;" line31="        P8," line32="        //% block=&quot;P12&quot;" line33="        P12," line34="        //% block=&quot;P2&quot;" line35="        P2," line36="        //% block=&quot;P13&quot;" line37="        P13," line38="        //% block=&quot;P14&quot;" line39="        P14," line40="        //% block=&quot;P15&quot;" line41="        P15," line42="        //% block=&quot;P16&quot;" line43="        P16," line44="    }" line45="    export let SensorChannels: { [key: number]: DigitalPin } = {" line46="        [SensorChannel.P1]: DigitalPin.P1," line47="        [SensorChannel.P8]: DigitalPin.P8," line48="        [SensorChannel.P12]: DigitalPin.P12," line49="        [SensorChannel.P2]: DigitalPin.P2," line50="        [SensorChannel.P13]: DigitalPin.P13," line51="        [SensorChannel.P14]: DigitalPin.P14," line52="        [SensorChannel.P15]: DigitalPin.P15," line53="        [SensorChannel.P16]: DigitalPin.P16," line54="    }" line55="    export let SensorChannelA: { [key: number]: AnalogPin } = {" line56="        [SensorChannel.P1]: AnalogPin.P1," line57="        [SensorChannel.P8]: AnalogPin.P8," line58="        [SensorChannel.P12]: AnalogPin.P12," line59="        [SensorChannel.P2]: AnalogPin.P2," line60="        [SensorChannel.P13]: AnalogPin.P13," line61="        [SensorChannel.P14]: AnalogPin.P14," line62="        [SensorChannel.P15]: AnalogPin.P15," line63="        [SensorChannel.P16]: AnalogPin.P16," line64="    }" line65="    //----------------------------------" line66="" line67="" line68="    export enum BlackChannel {" line69="        //% block=&quot;P1&quot;" line70="        P1," line71="        //% block=&quot;P8&quot;" line72="        P8," line73="        //% block=&quot;P12&quot;" line74="        P12," line75="        //% block=&quot;P2&quot;" line76="        P2," line77="        //% block=&quot;P13&quot;" line78="        P13," line79="        //% block=&quot;P14&quot;" line80="        P14," line81="        //% block=&quot;P15&quot;" line82="        P15," line83="        //% block=&quot;P16&quot;" line84="        P16," line85="    }" line86="    export let BlackChannels: { [key: number]: DigitalPin } = {" line87="        [BlackChannel.P1]: DigitalPin.P1," line88="        [BlackChannel.P8]: DigitalPin.P8," line89="        [BlackChannel.P12]: DigitalPin.P12," line90="        [BlackChannel.P2]: DigitalPin.P2," line91="        [BlackChannel.P13]: DigitalPin.P13," line92="        [BlackChannel.P14]: DigitalPin.P14," line93="        [BlackChannel.P15]: DigitalPin.P15," line94="        [BlackChannel.P16]: DigitalPin.P16," line95="    }" line96="    //% color=#000000" line97="    //% block=&quot;read button $pin (0-1)&quot;" line98="    //% group=&quot;Read Sensor&quot;" line99="    export function readbutton(pin: ButtonChannel): number {" line100="        let read = ButtonChannels[pin];" line101="        pins.setPull(ButtonChannels[pin], PinPullMode.PullUp);" line102="        let reading = pins.digitalReadPin(read);" line103="        return (reading);" line104="    }" line105="    //% color=#000000    " line106="    //% block=&quot;analog Sensor $pin (0-1023) &quot;" line107="    //% group=&quot;Read Sensor&quot;" line108="    export function lightSensor(pin: SensorChannel): number {" line109="        let read2 = SensorChannelA[pin];" line110="        let reading2 = pins.analogReadPin(read2);" line111="        //let mappin = pins.map(reading, 0, 1023, 0, 10); // แปลงค่าจาก 0-1023 เป็น 0-10" line112="        return Math.round(reading2);" line113="    }" line114="" line115="    //% color=#000000    " line116="    //% block=&quot;digital Sensor $pin (0-1)&quot;" line117="    //% group=&quot;Read Sensor&quot;" line118="    export function Sensor(pin: SensorChannel): number {" line119="        let read3 = SensorChannels[pin];" line120="        let reading3 = pins.digitalReadPin(read3);" line121="        return (reading3);" line122="    }" line123="" line124="" line125="    function signal_dht11(pin: DigitalPin): void {" line126="        pins.digitalWritePin(pin, 0);" line127="        basic.pause(18);" line128="        let l = pins.digitalReadPin(pin);" line129="        pins.setPull(pin, PinPullMode.PullUp);" line130="    }" line131="" line132="" line133="    //% color=#383838" line134="    //% block=&quot;track Line $pin Black Color&quot;" line135="    //% group=&quot;Logic Sensor&quot;" line136="    export function isblack(pin: BlackChannel): boolean {" line137="        let read4 = BlackChannels[pin];" line138="        return pins.digitalReadPin(read4) == 1;" line139="    }" line140="    //% color=#636262" line141="    //% block=&quot;track Line $pin Not Black&quot;" line142="    //% group=&quot;Logic Sensor&quot;" line143="    export function notblack(pin: BlackChannel): boolean {" line144="        let read5 = BlackChannels[pin];" line145="        return pins.digitalReadPin(read5) == 0;" line146="    }" line147="" line148="" line149="    //% color=#3D3430    " line150="    //% block=&quot;on button $pin pressed&quot;" line151="    //% group=&quot;Logic Sensor&quot;" line152="    export function isButtonPressed(pin: ButtonChannel): boolean {" line153="        pins.setPull(ButtonChannels[pin], PinPullMode.PullUp);" line154="        let read6 = ButtonChannels[pin];" line155="        return pins.digitalReadPin(read6) == 0;" line156="    }" line157="" line158="" line159="" line160="" line161="" line162="" line163="" line164="    function dht11_read(pin: DigitalPin): number {" line165="        signal_dht11(pin);" line166="" line167="        // Wait for response header to finish" line168="        while (pins.digitalReadPin(pin) == 1);" line169="        while (pins.digitalReadPin(pin) == 0);" line170="        while (pins.digitalReadPin(pin) == 1);" line171="" line172="        let value = 0;" line173="        let counter = 0;" line174="" line175="        for (let n = 0; n &lt;= 32 - 1; n++) {" line176="            while (pins.digitalReadPin(pin) == 0);" line177="            counter = 0" line178="            while (pins.digitalReadPin(pin) == 1) {" line179="                counter += 1;" line180="            }" line181="            if (counter &gt; 4) {" line182="                value = value + (1 &lt;&lt; (31 - n));" line183="            }" line184="        }" line185="        return value;" line186="    }" line187="" line188="    export enum Dht11Result {" line189="        //% block=&quot;Celsius&quot;" line190="        Celsius," line191="        //% block=&quot;Fahrenheit&quot;" line192="        Fahrenheit," line193="        //% block=&quot;humidity&quot;" line194="        humidity" line195="    }" line196="" line197="    //% group=&quot;thermometer&quot;" line198="    //% color=#76dbb1" line199="    //% blockId=get_DHT11_value block=&quot;dht11 set pin %pin_arg|get %dhtResult&quot; blockExternalInputs=true" line200="    //% pin_arg.fieldEditor=&quot;gridpicker&quot; pin_arg.fieldOptions.columns=4" line201="    //% pin_arg.fieldOptions.tooltips=&quot;false&quot; pin_arg.fieldOptions.width=&quot;300&quot;" line202="    export function get_DHT11_value(pin_arg: DigitalPin, dhtResult: Dht11Result): number {" line203="        switch (dhtResult) {" line204="            case Dht11Result.Celsius: return (dht11_read(pin_arg) &amp; 0x0000ff00) &gt;&gt; 8;" line205="            case Dht11Result.Fahrenheit: return ((dht11_read(pin_arg) &amp; 0x0000ff00) &gt;&gt; 8) * 9 / 5 + 32;" line206="            case Dht11Result.humidity: return dht11_read(pin_arg) &gt;&gt; 24;" line207="            default: return 0;" line208="        }" line209="    }" line210="" line211="" line212="" line213="    //MLX90614_TEMPERATURE" line214="    let MLX90614_I2C_ADDR = 0x5A" line215="" line216="    function read_reg_uint16(reg: number): number {" line217="        pins.i2cWriteNumber(MLX90614_I2C_ADDR, reg, NumberFormat.UInt8LE, true);" line218="        return pins.i2cReadNumber(MLX90614_I2C_ADDR, NumberFormat.UInt16LE);" line219="    }" line220="" line221="    /**" line222="     * temperature" line223="     */" line224="    //MLX90614 IR thermometer" line225="" line226="    export enum MLX90614_TEMPERATURE_ORIGIN {" line227="        //% block=&quot;object&quot;" line228="        OBJECT = 0x07," line229="        //% block=&quot;ambient&quot;" line230="        AMBIENT = 0x06," line231="    }" line232="" line233="" line234="    //% color=#76dbb1" line235="    //% blockId=&quot;mlx90614_TEMPERATURE&quot; block=&quot;%temperature_origin temperature (°C)&quot;" line236="    //% weight=80 blockGap=8" line237="    //% group=&quot;MLX90614 IR thermometer&quot;" line238="    export function temperature(temperature_origin: MLX90614_TEMPERATURE_ORIGIN): number {" line239="        let u = read_reg_uint16(temperature_origin);" line240="        return u * 0.02 - 273.15;" line241="    }" line242="" line243="    //sonar" line244="    export enum PingUnitold {" line245="        //% block=&quot;μs&quot;" line246="        MicroSeconds," line247="        //% block=&quot;cm&quot;" line248="        Centimeters," line249="        //% block=&quot;inches&quot;" line250="        Inches" line251="    }" line252="    export enum SonarPort {" line253="        //% block=&quot;E [ trig(P16) echo(P15) ]&quot;" line254="        E," line255="        //% block=&quot;F [ trig(P14) echo(P13) ]&quot;" line256="        F," line257="        //% block=&quot;G [ trig(P2) echo(P12) ]&quot;" line258="        G," line259="        //% block=&quot;H [ trig(P8) echo(P1) ]&quot;" line260="        H," line261="    }" line262="    export let TrigChanelold: { [key: number]: DigitalPin } = {" line263="        [SonarPort.E]: DigitalPin.P16," line264="        [SonarPort.F]: DigitalPin.P14," line265="        [SonarPort.G]: DigitalPin.P2," line266="        [SonarPort.H]: DigitalPin.P8," line267="    }" line268="    export let EchoChanelolde: { [key: number]: DigitalPin } = {" line269="        [SonarPort.E]: DigitalPin.P15," line270="        [SonarPort.F]: DigitalPin.P13," line271="        [SonarPort.G]: DigitalPin.P12," line272="        [SonarPort.H]: DigitalPin.P1," line273="    }" line274="    //% color=#76dbb1" line275="    //sonar" line276="    //% block=&quot;sonar %channel unit %unit&quot;" line277="    //% group=&quot;ect&quot;" line278="    //% unit.defl=PingUnitold.Centimeters" line279="    export function ping(channel: SonarPort, unit: PingUnitold, maxCmDistance = 500): number {" line280="        let trig2 = TrigChanelold[channel];" line281="        let echo2 = EchoChanelolde[channel];" line282="        // send pulse" line283="        pins.setPull(trig2, PinPullMode.PullNone);" line284="        pins.digitalWritePin(trig2, 0);" line285="        control.waitMicros(2);" line286="        pins.digitalWritePin(trig2, 1);" line287="        control.waitMicros(10);" line288="        pins.digitalWritePin(trig2, 0);" line289="" line290="        // read pulse" line291="        const o = pins.pulseIn(echo2, PulseValue.High, maxCmDistance * 58);" line292="" line293="        switch (unit) {" line294="            case PingUnitold.Centimeters: return Math.idiv(o, 58);" line295="            case PingUnitold.Inches: return Math.idiv(o, 148);" line296="            default: return o;" line297="        }" line298="    }" line299="" line300="" line301="    //% color=#76dbb1" line302="    //% group=&quot;ect&quot;" line303="    //% block=&quot;ultrasonic trig %trig|echo %echo|get distance %unit&quot;" line304="    //% trig.fieldEditor=&quot;gridpicker&quot; trig.fieldOptions.columns=4" line305="    //% trig.fieldOptions.tooltips=&quot;false&quot; trig.fieldOptions.width=&quot;300&quot;" line306="    //% echo.fieldEditor=&quot;gridpicker&quot; echo.fieldOptions.columns=4" line307="    //% echo.fieldOptions.tooltips=&quot;false&quot; echo.fieldOptions.width=&quot;300&quot;" line308="    export function sensorping(trig: DigitalPin, echo: DigitalPin, unit: PingUnitold, maxCmDistance = 500): number {" line309="        // send pulse" line310="        pins.setPull(trig, PinPullMode.PullNone);" line311="        pins.digitalWritePin(trig, 0);" line312="        control.waitMicros(2);" line313="        pins.digitalWritePin(trig, 1);" line314="        control.waitMicros(10);" line315="        pins.digitalWritePin(trig, 0);" line316="" line317="        // read pulse" line318="        const p = pins.pulseIn(echo, PulseValue.High, maxCmDistance * 58);" line319="" line320="        switch (unit) {" line321="            case PingUnitold.Centimeters: return p / 58;" line322="            case PingUnitold.Inches: return p / 148;" line323="            default: return p;" line324="        }" line325="    }" line326="    //% group=&quot;ect&quot;" line327="    //% color=#76dbb1" line328="    //% blockId=octopus_pir weight=80 blockGap=30" line329="    //% block=&quot;motion detector at pin %p&quot;    " line330="" line331="    export function PIR(p: SensorChannel): boolean {" line332="        let q = SensorChannels[p];" line333="        let a: number = pins.digitalReadPin(q);" line334="        if (a == 1) {" line335="            return true;" line336="        } else return false;" line337="    }" line338="" line339="}" numlines="340"></mutation><next><block type="typescript_statement" id="$V1PaO5C!TJ@b|TVH(;x"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace GigoMotor {" line1="    // motor control" line2="    export enum MotorChannel {" line3="        //% block=&quot;E (P15,P16)&quot;" line4="        E," line5="        //% block=&quot;F (P13,P14)&quot;&quot;" line6="        F," line7="        //% block=&quot;G (P12,P2)&quot;&quot;" line8="        G," line9="        //% block=&quot;H (P1,P8)&quot;&quot;" line10="        H," line11="    }" line12="    export enum MotorShaftDirection {" line13="        //% block=&quot;Left&quot;" line14="        LOW," line15="        //% block=&quot;Right&quot;" line16="        HIGH," line17="    }" line18="    export let MotorSDD: { [key: number]: number } = {" line19="        [MotorShaftDirection.LOW]: 0," line20="        [MotorShaftDirection.HIGH]: 1," line21="    }" line22="    export let MotorSpeedPins: { [key: number]: AnalogPin } = {" line23="        [MotorChannel.E]: AnalogPin.P16," line24="        [MotorChannel.F]: AnalogPin.P14," line25="        [MotorChannel.G]: AnalogPin.P2," line26="        [MotorChannel.H]: AnalogPin.P8," line27="    }" line28="    export let MotorChannels: { [key: number]: DigitalPin } = {" line29="        [MotorChannel.E]: DigitalPin.P15," line30="        [MotorChannel.F]: DigitalPin.P13," line31="        [MotorChannel.G]: DigitalPin.P12," line32="        [MotorChannel.H]: DigitalPin.P1," line33="    }" line34="" line35="    //% color=#E7734B" line36="    //% direction.defl=MotorShaftDirection.HIGH" line37="    //% block=&quot;stop motor $channel&quot;" line38="    //% group=&quot;Motor&quot;" line39="    export function motorStop1(channel: MotorChannel): void {" line40="        let dirPin4 = MotorChannels[channel];" line41="        let speedPin4 = MotorSpeedPins[channel];" line42="" line43="        pins.digitalWritePin(dirPin4, 0);" line44="        pins.analogWritePin(speedPin4, 0);" line45="    }" line46="" line47="    //% color=#E7734B" line48="    //% block=&quot;motor $channel direction $direction speed $speed&quot;" line49="    //% speed.min=0 speed.max=255" line50="    //% speed.defl=100" line51="    //% direction.min=0 direction.max=1" line52="    //% group=&quot;Motor&quot;" line53="    //% color=#E7734B" line54="    export function motorControl1(channel: MotorChannel, direction: number, speed: number): void {" line55="        let dirPin5 = MotorChannels[channel];" line56="        let speedPin5 = MotorSpeedPins[channel];" line57="" line58="        pins.digitalWritePin(dirPin5, direction);" line59="        pins.analogWritePin(speedPin5, pins.map(speed, 0, 255, 0, 1023));" line60="    }" line61="" line62="    //% color=#E7734B" line63="    //% block=&quot;motor $channel direction $direction speed $speed&quot;" line64="    //% speed.min=0 speed.max=255" line65="    //% speed.defl=100" line66="    //% direction.defl=motor.MotorShaftDirection.HIGH" line67="    //% group=&quot;Motor&quot;" line68="    //% color=#E7734B" line69="    export function motorControl2(channel: MotorChannel, direction: MotorShaftDirection, speed: number): void {" line70="        let dirPin6 = MotorChannels[channel];" line71="        let speedPin6 = MotorSpeedPins[channel];" line72="        let direct = MotorSDD[direction];" line73="        pins.digitalWritePin(dirPin6, direct);" line74="        pins.analogWritePin(speedPin6, pins.map(speed, 0, 255, 0, 1023));" line75="    }" line76="" line77="    //servo180" line78="    export enum ServoChannel {" line79="        //% block=&quot;P1&quot;" line80="        P1," line81="        //% block=&quot;P8&quot;" line82="        P8," line83="        //% block=&quot;P12&quot;" line84="        P12," line85="        //% block=&quot;P2&quot;" line86="        P2," line87="        //% block=&quot;P13&quot;" line88="        P13," line89="        //% block=&quot;P14&quot;" line90="        P14," line91="        //% block=&quot;P15&quot;" line92="        P15," line93="        //% block=&quot;P16&quot;" line94="        P16," line95="    }" line96="    export let ServoChannels: { [key: number]: AnalogPin } = {" line97="        [ServoChannel.P1]: AnalogPin.P1," line98="        [ServoChannel.P8]: AnalogPin.P8," line99="        [ServoChannel.P12]: AnalogPin.P12," line100="        [ServoChannel.P2]: AnalogPin.P2," line101="        [ServoChannel.P13]: AnalogPin.P13," line102="        [ServoChannel.P14]: AnalogPin.P14," line103="        [ServoChannel.P15]: AnalogPin.P15," line104="        [ServoChannel.P16]: AnalogPin.P16," line105="    }" line106="    //----------------------------------" line107="" line108="    export enum ServoconChannel {" line109="        //% block=&quot;P1&quot;" line110="        P1," line111="        //% block=&quot;P8&quot;" line112="        P8," line113="        //% block=&quot;P12&quot;" line114="        P12," line115="        //% block=&quot;P2&quot;" line116="        P2," line117="        //% block=&quot;P13&quot;" line118="        P13," line119="        //% block=&quot;P14&quot;" line120="        P14," line121="        //% block=&quot;P15&quot;" line122="        P15," line123="        //% block=&quot;P16&quot;" line124="        P16," line125="    }" line126="    export let ServoconChannels: { [key: number]: AnalogPin } = {" line127="        [ServoconChannel.P1]: AnalogPin.P1," line128="        [ServoconChannel.P8]: AnalogPin.P8," line129="        [ServoconChannel.P12]: AnalogPin.P12," line130="        [ServoconChannel.P2]: AnalogPin.P2," line131="        [ServoconChannel.P13]: AnalogPin.P13," line132="        [ServoconChannel.P14]: AnalogPin.P14," line133="        [ServoconChannel.P15]: AnalogPin.P15," line134="        [ServoconChannel.P16]: AnalogPin.P16," line135="    }" line136="    export enum SvconShaft {" line137="        //% block=&quot;Right&quot;" line138="        Right = 0," line139="        //% block=&quot;Left&quot;" line140="        Left = 180," line141="        //% block=&quot;Stop&quot;" line142="        Stop = 90," line143="" line144="    }" line145="    export let DegreesCon: { [key: number]: number } = {" line146="        [SvconShaft.Right]: 0," line147="        [SvconShaft.Left]: 180," line148="        [SvconShaft.Stop]: 90," line149="" line150="    }" line151="" line152="    //% color=#E84E19" line153="    //% block&quot;servo180 $pinSmini degrees $degrees&quot;" line154="    //% degrees.min=20 degrees.max=160" line155="    //% degrees.defl=90" line156="    //% group=&quot;Servo&quot;" line157="    export function miniServo(pinSmini: ServoChannel, degrees: number): void {" line158="        let pinsmini = ServoChannels[pinSmini];" line159="        pins.servoWritePin(pinsmini, degrees);" line160="" line161="    }" line162="    //% color=#E84E19" line163="    //% block&quot;continuous Servo $pinSV direction $direction&quot;" line164="    //% direction.defl=90" line165="    //% group=&quot;Servo&quot;" line166="    export function continuousServo(pinSV: ServoChannel, direction: SvconShaft): void {" line167="        let pinservo = ServoChannels[pinSV];" line168="        pins.servoWritePin(pinservo, direction);" line169="" line170="    }" line171="}" numlines="172"></mutation><next><block type="typescript_statement" id="T+uED)`5wij({Yr48X]]"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace LCD1602 {" line1="    //LCD i2c" line2="" line3="" line4="    let i2cAddr: number // 0x3F: PCF8574A, 0x27: PCF8574" line5="    let BK: number      // backlight control" line6="    let RS: number      // command/data" line7="" line8="    // set LCD reg" line9="    function setreg(d: number) {" line10="        pins.i2cWriteNumber(i2cAddr, d, NumberFormat.Int8LE)" line11="        basic.pause(1)" line12="    }" line13="" line14="    // send data to I2C bus" line15="    function set(d: number) {" line16="        d = d &amp; 0xF0" line17="        d = d + BK + RS" line18="        setreg(d)" line19="        setreg(d + 4)" line20="        setreg(d)" line21="    }" line22="" line23="    // send command" line24="    function cmd(d: number) {" line25="        RS = 0" line26="        set(d)" line27="        set(d &lt;&lt; 4)" line28="    }" line29="" line30="    // send data" line31="    function dat(d: number) {" line32="        RS = 1" line33="        set(d)" line34="        set(d &lt;&lt; 4)" line35="    }" line36="" line37="    // auto get LCD address" line38="    function AutoAddr() {" line39="        let v = true" line40="        let addr = 0x20" line41="        let d1 = 0, d2 = 0" line42="        while (v &amp;&amp; (addr &lt; 0x28)) {" line43="            pins.i2cWriteNumber(addr, -1, NumberFormat.Int32LE)" line44="            d1 = pins.i2cReadNumber(addr, NumberFormat.Int8LE) % 16" line45="            pins.i2cWriteNumber(addr, 0, NumberFormat.Int16LE)" line46="            d2 = pins.i2cReadNumber(addr, NumberFormat.Int8LE)" line47="            if ((d1 == 7) &amp;&amp; (d2 == 0)) v = false" line48="            else addr += 1" line49="        }" line50="        if (!v) return addr" line51="" line52="        addr = 0x38" line53="        while (v &amp;&amp; (addr &lt; 0x40)) {" line54="            pins.i2cWriteNumber(addr, -1, NumberFormat.Int32LE)" line55="            d1 = pins.i2cReadNumber(addr, NumberFormat.Int8LE) % 16" line56="            pins.i2cWriteNumber(addr, 0, NumberFormat.Int16LE)" line57="            d2 = pins.i2cReadNumber(addr, NumberFormat.Int8LE)" line58="            if ((d1 == 7) &amp;&amp; (d2 == 0)) v = false" line59="            else addr += 1" line60="        }" line61="        if (!v) return addr" line62="        else return 0" line63="" line64="    }" line65="" line66="" line67="    //% color=#045F14" line68="    //% blockId=&quot;i2c_LCD1620_SET_ADDRESS&quot; block=&quot;lcd (A) Address %addr&quot;" line69="    //% weight=100 blockGap=8" line70="    //% parts=LCD1602_I2C trackArgs=0" line71="    //% group=&quot;LCD i2c&quot;" line72="    export function LcdInit(Addr: number) {" line73="        if (Addr == 0) i2cAddr = AutoAddr()" line74="        else i2cAddr = Addr" line75="        BK = 8" line76="        RS = 0" line77="        cmd(0x33)       // set 4bit mode" line78="        basic.pause(5)" line79="        set(0x30)" line80="        basic.pause(5)" line81="        set(0x20)" line82="        basic.pause(5)" line83="        cmd(0x28)       // set mode" line84="        cmd(0x0C)" line85="        cmd(0x06)" line86="        cmd(0x01)       // clear" line87="    }" line88="" line89="    //% color=#045F14" line90="    //% blockId=&quot;i2c_LCD1620_SHOW_NUMBER&quot; block=&quot;show number %n|at x %x|y %y&quot;" line91="    //% weight=90 blockGap=8" line92="    //% x.min=0 x.max=15" line93="    //% y.min=0 y.max=1" line94="    //% parts=LCD1602_I2C trackArgs=0" line95="    //% group=&quot;LCD i2c&quot;" line96="    export function ShowNumber(n: number, x: number, y: number): void {" line97="        let w = n.toString()" line98="        ShowString(w, x, y)" line99="    }" line100="" line101="    //% color=#045F14" line102="    //% blockId=&quot;i2c_LCD1620_SHOW_STRING&quot; block=&quot;show string %s|at x %x|y %y&quot;" line103="    //% weight=90 blockGap=8" line104="    //% x.min=0 x.max=15" line105="    //% y.min=0 y.max=1" line106="    //% parts=LCD1602_I2C trackArgs=0" line107="    //% group=&quot;LCD i2c&quot;" line108="    export function ShowString(s: string, x: number, y: number): void {" line109="        let a2: number" line110="" line111="        if (y &gt; 0)" line112="            a2 = 0xC0" line113="        else" line114="            a2 = 0x80" line115="        a2 += x" line116="        cmd(a2)" line117="" line118="        for (let i2 = 0; i2 &lt; s.length; i2++) {" line119="            dat(s.charCodeAt(i2))" line120="        }" line121="    }" line122="" line123="    //% color=#045F14" line124="    //% blockId=&quot;i2c_LCD1620_ON&quot; block=&quot;lcd on&quot;" line125="    //% weight=81 blockGap=8" line126="    //% parts=LCD1602_I2C trackArgs=0" line127="    //% group=&quot;LCD i2c&quot;" line128="    export function on(): void {" line129="        cmd(0x0C)" line130="    }" line131="" line132="    //% color=#045F14" line133="    //% blockId=&quot;i2c_LCD1620_OFF&quot; block=&quot;lcd off&quot;" line134="    //% weight=80 blockGap=8" line135="    //% parts=LCD1602_I2C trackArgs=0" line136="    //% group=&quot;LCD i2c&quot;" line137="    export function off(): void {" line138="        cmd(0x08)" line139="    }" line140="" line141="    //% color=#045F14" line142="    //% blockId=&quot;i2c_LCD1620_CLEAR&quot; block=&quot;clear&quot;" line143="    //% weight=85 blockGap=8" line144="    //% parts=LCD1602_I2C trackArgs=0" line145="    //% group=&quot;LCD i2c&quot;" line146="    export function clear(): void {" line147="        cmd(0x01)" line148="    }" line149="" line150="    //% color=#045F14" line151="    //% blockId=&quot;i2c_LCD1620_BACKLIGHT_ON&quot; block=&quot;light on&quot;" line152="    //% weight=71 blockGap=8" line153="    //% parts=LCD1602_I2C trackArgs=0" line154="    //% group=&quot;LCD i2c&quot;" line155="    export function BacklightOn(): void {" line156="        BK = 8" line157="        cmd(0)" line158="    }" line159="" line160="    //% color=#045F14" line161="    //% blockId=&quot;i2c_LCD1620_BACKLIGHT_OFF&quot; block=&quot;light off &quot;" line162="    //% weight=70 blockGap=8" line163="    //% parts=LCD1602_I2C trackArgs=0" line164="    //% group=&quot;LCD i2c&quot;" line165="    export function BacklightOff(): void {" line166="        BK = 0" line167="        cmd(0)" line168="    }" line169="" line170="" line171="" line172="}" numlines="173"></mutation><next><block type="typescript_statement" id="2}@7EQUjkAB$`%/{+snc"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Joystick {" line1="    // joystick control" line2="    export enum Joymove {" line3="        //% blockId=&quot;Nostate&quot; block=&quot;stop&quot;" line4="        Stop," line5="        //% block=&quot;Up&quot;" line6="        Up," line7="        //% block=&quot;Down&quot;" line8="        Down," line9="        //% block=&quot;Left&quot;" line10="        Left," line11="        //% block=&quot;Right&quot;" line12="        Right," line13="    }" line14="" line15="    export enum DfButton {" line16="        //% block=&quot;red&quot;" line17="        Red," line18="        //% block=&quot;blue&quot;" line19="        Blue," line20="        //% block=&quot;green&quot;" line21="        Green," line22="        //% block=&quot;yellow&quot;" line23="        Yellow," line24="        //% block=&quot;A&quot;" line25="        A," line26="        //% block=&quot;B&quot;" line27="        B," line28="    }" line29="    export let EnButtonChannels: { [key: number]: DigitalPin } = {" line30="        [DfButton.Red]: DigitalPin.P15," line31="        [DfButton.Blue]: DigitalPin.P16," line32="        [DfButton.Green]: DigitalPin.P13," line33="        [DfButton.Yellow]: DigitalPin.P14," line34="        [DfButton.A]: DigitalPin.P5," line35="        [DfButton.B]: DigitalPin.P11" line36="    }" line37="    // Store the previous state of the buttons" line38="    let buttonStates: { [key: number]: boolean } = {" line39="        [DfButton.Red]: false," line40="        [DfButton.Blue]: false," line41="        [DfButton.Green]: false," line42="        [DfButton.Yellow]: false," line43="        [DfButton.A]: false," line44="        [DfButton.B]: false" line45="    }" line46="" line47="    export enum EnRocker {" line48="        //% blockId=&quot;Nostate&quot; block=&quot;Nostate&quot;" line49="        Nostate = 0," line50="        //% blockId=&quot;Up&quot; block=&quot;Up&quot;" line51="        Up," line52="        //% blockId=&quot;Down&quot; block=&quot;Down&quot;" line53="        Down," line54="        //% blockId=&quot;Left&quot; block=&quot;Left&quot;" line55="        Left," line56="        //% blockId=&quot;Right&quot; block=&quot;Right&quot;" line57="        Right," line58="        //% blockId=&quot;Press&quot; block=&quot;Press&quot;" line59="        Press" line60="    }" line61="" line62="    export enum EnButtonState {" line63="        //% blockId=&quot;Press&quot; block=&quot;Press&quot;" line64="        Press = 0," line65="        //% blockId=&quot;Realse&quot; block=&quot;Realse&quot;" line66="        Realse = 1" line67="    }" line68="    export enum EnButtonStateDF {" line69="        Press = 0," line70="        Release = 1" line71="    }" line72="    export enum EnButton {" line73="" line74="        B1 = 0," line75="        B2," line76="        B3," line77="        B4" line78="    }" line79="    //% group=&quot;DFrobot&quot;" line80="    //% color=#383838" line81="    //% block=&quot;button %num| is %value&quot;" line82="    export function ButtonDF(num: DfButton, value: EnButtonStateDF): boolean {" line83="        let pin = EnButtonChannels[num];" line84="        pins.setPull(pin, PinPullMode.PullUp);" line85="        let currentState = pins.digitalReadPin(pin) == 0;" line86="" line87="        // Check for button press or release" line88="        if (value == EnButtonStateDF.Press &amp;&amp; currentState &amp;&amp; !buttonStates[num]) {" line89="            buttonStates[num] = true;" line90="            return true;" line91="        } else if (value == EnButtonStateDF.Release &amp;&amp; !currentState &amp;&amp; buttonStates[num]) {" line92="            buttonStates[num] = false;" line93="            return true;" line94="        }" line95="        return false;" line96="    }" line97="" line98="    //% color=#383838" line99="    //% block=&quot;joystick is pressed&quot;" line100="    //% group=&quot;DFrobot&quot;" line101="    export function joypressed(): boolean {" line102="        pins.setPull(DigitalPin.P8, PinPullMode.PullUp);" line103="        let read7 = DigitalPin.P8;" line104="        return pins.digitalReadPin(read7) == 0;" line105="    }" line106="    //% color=#383838" line107="    //% block=&quot;joystick is %pin&quot;" line108="    //% group=&quot;DFrobot&quot;" line109="    export function joystickmove(pin: Joymove): boolean {" line110="        let x2 = pins.analogReadPin(AnalogPin.P1);" line111="        let y = pins.analogReadPin(AnalogPin.P2);" line112="        let now_state = Joymove.Stop;" line113="        if (x2 &lt; 300) {" line114="" line115="            now_state = Joymove.Left;" line116="" line117="        }" line118="        else if (x2 &gt; 600) {" line119="" line120="            now_state = Joymove.Right;" line121="        }" line122="        else {" line123="            if (y &lt; 300) {" line124="                now_state = Joymove.Down;" line125="            }" line126="            else if (y &gt; 600) {" line127="                now_state = Joymove.Up;" line128="            }" line129="        }" line130="" line131="        if (now_state == pin)" line132="            return true;" line133="        else" line134="            return false;" line135="" line136="    }" line137="" line138="    //---------------------------------------------------" line139="    //% group=&quot;GHBit&quot;" line140="    //% blockId=ghBit_Rocker block=&quot;rocker|value %value&quot;" line141="    //% weight=96" line142="    //% blockGap=10" line143="    //% color=&quot;#C814B8&quot;" line144="    //% name.fieldEditor=&quot;gridpicker&quot; name.fieldOptions.columns=6" line145="    export function Rocker(value: EnRocker): boolean {" line146="" line147="        pins.setPull(DigitalPin.P8, PinPullMode.PullUp);" line148="        let x3 = pins.analogReadPin(AnalogPin.P1);" line149="        let y2 = pins.analogReadPin(AnalogPin.P2);" line150="        let z = pins.digitalReadPin(DigitalPin.P8);" line151="        let now_state2 = EnRocker.Nostate;" line152="" line153="        if (x3 &lt; 200) {" line154="" line155="            now_state2 = EnRocker.Up;" line156="" line157="        }" line158="        else if (x3 &gt; 730) {" line159="" line160="            now_state2 = EnRocker.Down;" line161="        }" line162="        else {" line163="            if (y2 &lt; 200) {" line164="                now_state2 = EnRocker.Right;" line165="            }" line166="            else if (y2 &gt; 730) {" line167="                now_state2 = EnRocker.Left;" line168="            }" line169="        }" line170="        if (z == 0)" line171="            now_state2 = EnRocker.Press;" line172="        if (now_state2 == value)" line173="            return true;" line174="        else" line175="            return false;" line176="" line177="    }" line178="    //% group=&quot;GHBit&quot;" line179="    //% blockId=ghBit_Button block=&quot;button| %num|value %value&quot;" line180="    //% weight=95" line181="    //% blockGap=10" line182="    //% color=&quot;#C814B8&quot;" line183="    //% name.fieldEditor=&quot;gridpicker&quot; name.fieldOptions.columns=5" line184="    export function Button(num: EnButton, value: EnButtonState): boolean {" line185="        let temp2 = false;" line186="        switch (num) {" line187="            case EnButton.B1: {" line188="                pins.setPull(DigitalPin.P13, PinPullMode.PullUp);" line189="                if (pins.digitalReadPin(DigitalPin.P13) == value) {" line190="                    temp2 = true;" line191="                }" line192="                else {" line193="                    temp2 = false;" line194="                }" line195="                break;" line196="            }" line197="            case EnButton.B2: {" line198="                pins.setPull(DigitalPin.P14, PinPullMode.PullUp);" line199="                if (pins.digitalReadPin(DigitalPin.P14) == value) {" line200="                    temp2 = true;" line201="                }" line202="                else {" line203="                    temp2 = false;" line204="                }" line205="                break;" line206="            }" line207="            case EnButton.B3: {" line208="                pins.setPull(DigitalPin.P15, PinPullMode.PullUp);" line209="                if (pins.digitalReadPin(DigitalPin.P15) == value) {" line210="                    temp2 = true;" line211="                }" line212="                else {" line213="                    temp2 = false;" line214="                }" line215="                break;" line216="            }" line217="            case EnButton.B4: {" line218="                pins.setPull(DigitalPin.P16, PinPullMode.PullUp);" line219="                if (pins.digitalReadPin(DigitalPin.P16) == value) {" line220="                    temp2 = true;" line221="                }" line222="                else {" line223="                    temp2 = false;" line224="                }" line225="                break;" line226="            }" line227="        }" line228="        return temp2;" line229="    }" line230="" line231="" line232="" line233="}" numlines="234"></mutation></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>